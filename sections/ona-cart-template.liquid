{%- liquid
  assign cart_notes_enable = section.settings.cart_notes_enable
-%}

{%- capture cart_children -%}
<div class="page-width" data-section-id="{{ section.id }}" data-section-type="cart-template">

  <div {% if cart.item_count == 0 %}class="hide" {% endif %}data-cart-wrapper>
    <div class="cart-header">
      <h1 class="cart-header__title">Cart</h1>
      <a href="{{ routes.all_products_collection_url }}" class="text-link text-link--accent">
        Continue shopping
      </a>
    </div>

    {%- comment -%} CLS fix: reserve vertical space for qikify reward bar (injected by JS) so cart rows below don't shift when it appears. 44px ≈ rendered bar height. {%- endcomment -%}
    <div class="cart-reward-bar-slot" style="min-height:44px">
      {%- render 'qikify-reward-bar' -%}
    </div>

    <form action="{{ routes.cart_url }}" method="post" novalidate class="cart" id="cart-form">
      <table>
        <thead class="cart__row cart__row--heading">
          <tr>
            <th scope="col">Product</th>
            <th class="text-right" scope="col">Price</th>
            <th class="text-right small--hide" scope="col">Quantity</th>
            <th class="text-right small--hide" scope="col">Total</th>
          </tr>
        </thead>
        <tbody>
          {%- for item in cart.items -%}
            {%- assign is_gift = false -%}
            {%- if item.id == 40126200709311 -%}{%- assign is_gift = true -%}{%- endif -%}
            <tr class="cart__row" data-item-id="{{ item.id }}" ref="cartItemRows[]" data-key="{{ item.key }}">
              <td class="cart__meta small--text-left">
                <div class="cart__product-information">
                  <div class="cart__image-wrapper">
                    {%- assign _ar = item.image.aspect_ratio | default: 1 -%}
                    {%- assign _w = _ar | times: 190 | round -%}
                    <img class="cart__image{% if item.image == null %} hide{% endif %}" src="{{ item | img_url: 'x190' }}" width="{{ _w }}" height="190" loading="lazy" decoding="async" alt="{{ item.image.alt | escape }}">
                  </div>
                  <div>
                    <div class="list-view-item__title">
                      <a href="{{ item.url }}" class="cart__product-title">{{ item.product.title }}</a>
                      {%- if item.selling_plan_allocation -%}
                        {%- assign sp_name = item.selling_plan_allocation.selling_plan.name | downcase -%}
                        {%- if sp_name contains 'prepaid' -%}
                          <p class="cart-item-note">⚠️ Prepaid subscriptions are paid upfront and cannot be cancelled. Shipments continue until the prepaid term ends.</p>
                        {%- else -%}
                          <p class="cart-item-note">⚠️ Ongoing subscription products can only be cancelled after two deliveries (initial + one). You can still pause or skip anytime. Prepaid subscriptions are paid upfront and cannot be cancelled. Shipments continue until the prepaid term ends.</p>
                        {%- endif -%}
                      {%- endif -%}
                    </div>

                    {%- assign property_size = item.properties | size -%}
                    {%- if item.product.has_only_default_variant == false or property_size > 0 or item.selling_plan_allocation -%}
                      <ul class="product-details">
                        {%- unless item.product.has_only_default_variant -%}
                          {%- for option in item.options_with_values -%}
                            <li class="product-details__item product-details__item--variant-option">{{ option.name }}: {{ option.value }}</li>
                          {%- endfor -%}
                        {%- endunless -%}
                        {%- if item.selling_plan_allocation -%}
                          <li class="product-details__item product-details__item--property">{{ item.selling_plan_allocation.selling_plan.name }}</li>
                        {%- endif -%}
                        {%- for p in item.properties -%}
                          {%- assign first_char = p.first | slice: 0 -%}
                          {%- if p.last != blank and first_char != '_' -%}
                            <li class="product-details__item product-details__item--property">
                              <span class="product-details__item-label">{{ p.first }}: </span>
                              {%- if p.last contains '/uploads/' -%}<a href="{{ p.last }}">{{ p.last | split: '/' | last }}</a>{%- else -%}{{ p.last }}{%- endif -%}
                            </li>
                          {%- endif -%}
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}

                    {%- unless is_gift -%}
                      <p class="cart__remove">
                        <button type="button" class="custom-cart-remove-line button-unstyled" on:click="/onLineItemRemove/{{ item.index | plus: 1 }}" aria-label="Remove {{ item.title | escape }}">Remove</button>
                      </p>
                    {%- endunless -%}
                  </div>
                </div>
              </td>

              <td class="cart__price text-right">
                {%- if item.original_price != item.final_price -%}
                  <s>{{ item.original_price | money }}</s>
                  <span class="order-discount">{{ item.final_price | money }}</span>
                {%- elsif is_gift -%}
                  Free
                {%- else -%}
                  {{ item.original_price | money }}
                {%- endif -%}

                {%- if item.line_level_discount_allocations.size > 0 -%}
                  <ul class="order-discount order-discount--list">
                    {%- for d in item.line_level_discount_allocations -%}
                      <li class="order-discount__item">{{ d.discount_application.title }} (-{{ d.amount | money }})</li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </td>

              <td class="cart__quantity-td text-right small--hide">
                {%- assign can_update = item.instructions.can_update_quantity | default: true, allow_false: true -%}
                {% render 'quantity-selector',
                  product: item.product,
                  variant: item.variant,
                  in_cart_quantity: item.quantity,
                  line_index: item.index,
                  class: 'cart-primary-typography',
                  can_update_quantity: can_update
                %}
              </td>

              <td class="cart__final-price text-right small--hide">
                {%- if is_gift -%}Free{%- else -%}{{ item.final_line_price | money }}{%- endif -%}
              </td>

              <td class="cart-items__error hidden" ref="cartItemErrorContainer-{{ item.index | plus: 1 }}">
                <div class="cart-item__error" role="alert">
                  <small class="cart-item__error-text" ref="cartItemError-{{ item.index | plus: 1 }}"></small>
                </div>
              </td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>

      <div class="cart__footer">
        <div class="grid">
          {%- if cart_notes_enable -%}
            <div class="grid__item medium-up--one-half cart-note">
              <label for="CartSpecialInstructions" class="cart-note__label small--text-center">Order notes</label>
              <textarea name="note" id="CartSpecialInstructions" class="cart-note__input">{{ cart.note }}</textarea>

              {%- if localization.country.iso_code == 'US' -%}
                <div class="cart-note cart-note--country" style="margin:16px 0;padding:12px;border:1px solid #ddd;">
                  <strong>Shipping to the USA:</strong>
                  US government tariffs or import restrictions may limit delivery or add extra charges at customs. These fees aren't included at checkout.
                </div>
                <input type="hidden" name="attributes[Destination Country]" value="US">
                <input type="hidden" name="attributes[US Shipping Notice]" value="Customer saw customs/duties message">
              {%- endif -%}

              <p style="padding:20px 0px 20px 0px;"><a href="/pages/faq#shipping-link">International Terms and Conditions</a></p>
            </div>
          {%- endif -%}

          <div class="grid__item text-right small--text-center{% if cart_notes_enable %} medium-up--one-half{% endif %}">

            {%- if cart.cart_level_discount_applications.size > 0 -%}
              <div class="order-discount-card-wrapper">
                {%- for d in cart.cart_level_discount_applications -%}
                  <span class="order-discount order-discount--title order-discount--cart">{{ d.title }}</span>
                  <span class="order-discount order-discount--cart order-discount--cart-total">-{{ d.total_allocated_amount | money }}</span>
                {%- endfor -%}
              </div>
            {%- endif -%}

            <div class="cart-subtotal">
              <span class="cart-subtotal__title">SUBTOTAL BEFORE DELIVERY</span>
              <span class="cart-subtotal__price">Total: {{ cart.total_price | money_with_currency }}</span>
            </div>

            <div class="cart__shipping rte">{{ taxes_shipping_checkout }}</div>

            <div class="cart__buttons-container">
              <div class="cart-btns-row">
                <a class="go-back-shop-btn" href="/collections/all">CONTINUE SHOPPING</a>
                <div class="cart__submit-controls">
                  {%- assign normal_count = 0 -%}
                  {%- assign preorder_count = 0 -%}
                  {%- for item in cart.items -%}
                    {%- assign has_pp = false -%}
                    {%- for p in item.properties -%}{%- if p.last != blank -%}{%- assign has_pp = true -%}{%- endif -%}{%- endfor -%}
                    {%- if has_pp -%}{%- assign preorder_count = preorder_count | plus: 1 -%}{%- else -%}{%- assign normal_count = normal_count | plus: 1 -%}{%- endif -%}
                  {%- endfor -%}

                  {%- if normal_count > 0 and preorder_count > 0 -%}
                    <script>jQuery(document).ready(function(){ jQuery('.preorder-tips-popup').addClass('show-popup'); });</script>
                    <input disabled type="submit" name="checkout" class="cart__submit btn btn--small-wide hide-btn" value="Check out">
                  {%- else -%}
                    <input type="submit" name="checkout" class="cart__submit btn btn--small-wide" value="Check out">
                  {%- endif -%}
                </div>
              </div>
              {%- if additional_checkout_buttons -%}
                <div class="additional-checkout-buttons">{{ content_for_additional_checkout_buttons }}</div>
              {%- endif -%}
            </div>
          </div>
        </div>
      </div>
    </form>
  </div>

  <div class="empty-page-content{% if cart.item_count > 0 %} hide{% endif %} text-center" data-empty-page-content>
    <img class="empty-cart-svg" src="{{ 'crying-beans.gif' | asset_url }}" width="150" height="150" loading="eager" decoding="async" alt="empty cart">
    <h1>Your cart</h1>
    <p class="cart--empty-message">Your cart is currently empty.</p>
    <div class="cookie-message">
      <p>Enable cookies to use the shopping cart</p>
    </div>
    <a href="/collections/all" class="btn btn--has-icon-after cart__continue-btn">Continue shopping{% include 'icon-arrow-right' %}</a>
  </div>
</div>

<style>
  tr[data-item-id="40126200709311"] .cart__remove{display:none;}
</style>

<div class="preorder-tips-popup">
  <div class="popup-box">
    <button class="close-btn" type="button" onclick="this.closest('.preorder-tips-popup').classList.remove('show-popup')">×</button>
    <div class="popup-text">
      <h2>{{ settings.ppc_title | default: 'Pre-order items detected' }}</h2>
      {{ settings.ppc_content | default: '<p>Your cart contains both regular and pre-order items. Please check out separately.</p>' }}
    </div>
  </div>
</div>

<script src="{{ 'component-cart-items.js' | asset_url }}" type="module" fetchpriority="low"></script>
<script src="{{ 'component-cart-quantity-selector.js' | asset_url }}" type="module" fetchpriority="low"></script>
{%- endcapture -%}

{% render 'cart-items-component', children: cart_children, section_id: section.id %}

{% schema %}
{
  "name": "ONA cart",
  "settings": [
    {
      "type": "checkbox",
      "id": "cart_notes_enable",
      "label": "Enable cart notes",
      "default": false
    }
  ]
}
{% endschema %}
