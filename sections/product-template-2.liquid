<style>
header{
	background:#fff!important;
}
</style>
<div class="product-template__container"
  id="ProductSection-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="product"
  data-enable-history-state="true"
  data-ajax-enabled="{{ settings.enable_ajax }}"
>
  {% comment %}
    Get first variant, or deep linked one
  {% endcomment %}
  {%- assign current_variant = product.selected_or_first_available_variant -%}
  {%- assign product_image_zoom_size = '1024x1024' -%}
  {%- assign product_image_scale = '2' -%}
  {%- assign enable_image_zoom = section.settings.enable_image_zoom -%}
  {%- assign compare_at_price = current_variant.compare_at_price -%}
  {%- assign price = current_variant.price -%}

  {% case section.settings.media_size %}
    {% when 'small' %}
      {%- assign product_media_width = 'medium-up--one-third' -%}
      {%- assign product_description_width = 'medium-up--two-thirds' -%}
      {%- assign height = 345 -%}
    {% when 'medium' %}
      {%- assign product_media_width = 'medium-up--one-half' -%}
      {%- assign product_description_width = 'medium-up--one-half' -%}
      {%- assign height = 530 -%}
    {% when 'large' %}
      {%- assign product_media_width = 'medium-up--two-thirds' -%}
      {%- assign product_description_width = 'medium-up--one-third' -%}
      {%- assign height = 720 -%}
    {% when 'full' %}
      {%- assign product_media_width = '' -%}
      {%- assign product_description_width = '' -%}
      {%- assign height = 1090 -%}
      {%- assign enable_image_zoom = false -%}
  {% endcase %}


  
<section class="product-detail-slider t2">
    <div class="left wowo fadeInUp">
        <div class="slider-for">
          {% for media in product.media %}
              <div class="slider-list">
                  <img src="{{ media.preview_image | img_url: '1100x1100', scale: '1' }}" alt="">
              </div>
          {% endfor %}
        </div>
        <div class="slider-nav">
          {% for media in product.media %}
              <div class="slider-list">
                <div class="img-bg" style="background-image:url({{ media.preview_image | img_url: '350x350', scale: '1' }});"></div>
              </div>
          {% endfor %}
        </div>
    </div>
    <div class="right wowo fadeInUp">
        <div class="right-box">
          <h1>{{ product.title | escape }}</h1>
          <div class="product__price">
            {% include 'product-price', variant: current_variant, show_vendor: section.settings.show_vendor %}
          </div>
          <div class="product-content">{{ product.description }}</div>
          {%- if cart.taxes_included or shop.shipping_policy.body != blank -%}
          <div class="product-content" data-product-policies>
            {%- if cart.taxes_included -%}
            {{ 'products.product.include_taxes' | t }}
            {%- endif -%}
            {%- if shop.shipping_policy.body != blank -%}
            {{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}
            {%- endif -%}
          </div>
          {%- endif -%}
          
        {% capture "form_classes" -%}
          product-form product-form-{{ section.id }}
          {%- if section.settings.enable_payment_button and product.has_only_default_variant %} product-form--payment-button-no-variants {%- endif -%}
          {%- if current_variant.available == false %} product-form--variant-sold-out {%- endif -%}
        {%- endcapture %}
        {% if product.metafields.custom.sold_out.value != true %}
          {% form 'product', product, class:form_classes, novalidate: 'novalidate', data-product-form: '' %}
            {{ form | payment_terms }}
              {% if section.settings.show_quantity_selector %}
                <div class="product-form__controls-group">
                  <div class="product-form__item qty-wrap">
                    <label for="Quantity-{{ section.id }}">{{ 'products.product.quantity' | t }}</label>
                    <a href="javascript:void(0);" class="minus">-</a>
                    <input type="number" id="Quantity-{{ section.id }}"
                      name="quantity" value="1" min="1" pattern="[0-9]*"
                      class="product-form__input product-form__input--quantity" data-quantity-input
                    >
                    <a href="javascript:void(0);" class="plus">+</a>
                  </div>
                </div>
              {% endif %}
   			<div class="qty-options-row">
              {% unless product.has_only_default_variant %}
                <div class="product-form__controls-group">
                  {% for option in product.options_with_values %}
                    <div class="selector-wrapper js product-form__item">
                      <label for="SingleOptionSelector-{{ forloop.index0 }}">
                        {{ option.name }}
                      </label>
                      <select class="single-option-selector single-option-selector-{{ section.id }} product-form__input"
                        id="SingleOptionSelector-{{ forloop.index0 }}"
                        data-index="option{{ forloop.index }}"
                      >
                        {% for value in option.values %}
                          <option value="{{ value | escape }}"{% if option.selected_value == value %} selected="selected"{% endif %}>{{ value }}</option>
                        {% endfor %}
                      </select>
                    </div>
                  {% endfor %}
                </div>
              {% endunless %}

              <select name="id" id="ProductSelect-{{ section.id }}" class="product-form__variants no-js">
                {% for variant in product.variants %}
                  <option value="{{ variant.id }}"
                    {%- if variant == current_variant %} selected="selected" {%- endif -%}
                  >
                    {{ variant.title }}  {%- if variant.available == false %} - {{ 'products.product.sold_out' | t }}{% endif %}
                  </option>
                {% endfor %}
              </select>
          </div>

            <div class="product-form__error-message-wrapper product-form__error-message-wrapper--hidden{% if section.settings.enable_payment_button %} product-form__error-message-wrapper--has-payment-button{% endif %}"
              data-error-message-wrapper
              role="alert"
            >
              <span class="visually-hidden">{{ 'general.accessibility.error' | t }} </span>
              {% include 'icon-error' %}
              <span class="product-form__error-message" data-error-message>{{ 'products.product.quantity_minimum_message' | t }}</span>
            </div>

            <span class="appstle_stand_alone_selector" data-product-handle="{{ product.handle }}" style="display:none;"></span>

            <div class="product-form__controls-group product-form__controls-group--submit">
              <div class="product-form__item product-form__item--submit
                {%- if section.settings.enable_payment_button %} product-form__item--payment-button {%- endif -%}
                {%- if product.has_only_default_variant %} product-form__item--no-variants {%- endif -%}"
              >
                <button type="submit" name="add"
                  {% unless current_variant.available %} aria-disabled="true"{% endunless %}
                  aria-label="{% unless current_variant.available %}{{ 'products.product.sold_out' | t }}{% else %}{{ 'products.product.add_to_cart' | t }}{% endunless %}"
                  class="git-btn cart-btn product-form__cart-submit{% if section.settings.enable_payment_button and product.selling_plan_groups == empty %} btn--secondary-accent{% endif %}"
                  {% if settings.enable_ajax %}aria-haspopup="dialog"{% endif %}
                  data-add-to-cart>
                  <span data-add-to-cart-text>
                    {% unless current_variant.available %}
                      {{ 'products.product.sold_out' | t }}
                    {% else %}
                      {{ 'products.product.add_to_cart' | t }}
                    {% endunless %}
                    <span class="icon-cart"></span>
                  </span>
                  <span class="hide" data-loader>
                    {% include 'icon-spinner' %}
                  </span>
                </button>
                {% if section.settings.enable_payment_button %}
                  {{ form | payment_button }}
                {% endif %}

              </div>
            </div>
          {% endform %}
        {% endif %}


        <div class="product_single_custom_tag_black">
            {% assign custom_tag_status = product.metafields.custom_product.tag_status %}
            {% assign custom_tag_name = product.metafields.custom_product.tag_name.value %}
            {% assign custom_tag_color = product.metafields.custom_product.tag_color %}
            {% assign custom_tag_icon = product.metafields.custom_product.tag_icon %}
            {% assign custom_tag_low_stock_qty = product.metafields.custom_product.lowstock_inventory %}
            {% assign custom_tag_from_date = product.metafields.custom_product.from_date %}
            {% assign custom_tag_from_time = product.metafields.custom_product.from_time %}
            {% assign custom_tag_to_date = product.metafields.custom_product.to_date %}
            {% assign custom_tag_to_time = product.metafields.custom_product.to_time %}
            {% assign currentDatetime = "now" | date: "%Y-%m-%d %H:%M:%S" %}
            {% assign first_match_found = false %}
            {% assign first_match_to_date = '' %}
            {% assign custom_tag_type = product.metafields.custom_product.tag_type %}
            {% if custom_tag_status != blank %}
              {% assign total_instances = custom_tag_status.size %}
            {% else %}
              {% assign total_instances = 0 %}
            {% endif %}
           
            {% assign low_stock_found = false %}
            {% assign product_sold_out = false %}
            {% assign product_sale_tag = false %}
            
            {% if custom_tag_type contains 'Sale' %}
                {% assign product_sale_tag = false %}
            {% endif %}


            {% assign lowstock_index = '' %}
            {% assign lowstock_status = '' %}
            {% assign is_lowstock_and_active = false %}
            {% for tagtype in custom_tag_type %}
              {% if tagtype == 'Low Stock' %}
                {% assign lowstock_index = forloop.index0 %}
              {% endif %}
            {% endfor %}
            {% if lowstock_index != '' %}
              {% for tagstatus in custom_tag_status %}
                {% if forloop.index0 == lowstock_index %}
                  {% assign lowstock_status = tagstatus %}
                {% endif %}
                {% if lowstock_status == 'Active' %}
                  {% assign is_lowstock_and_active = true %}
                {% endif %}
              {% endfor %}

              {% for taglowstock in custom_tag_low_stock_qty %}
                {% if forloop.index0 == lowstock_index %}
                  {% assign lowstock_inventqty = taglowstock | plus: 0 %}
                {% endif %}
              {% endfor %}
            {% endif %}
           
            {% if custom_tag_type contains 'Low Stock' and product.first_available_variant.inventory_quantity <= lowstock_inventqty and is_lowstock_and_active == true %}
                {% assign low_stock_found = true %}  
            {% endif %}
          
            {% for i in (0..total_instances) %}
             
              {% if custom_tag_status[i] != 'Disable' %}
                   {% assign custommetafield_index = i | plus: 1 %}
                   {% if custom_tag_low_stock_qty[i] != '' %}
                     {% assign lowstock_inventory_limit = custom_tag_low_stock_qty[i] | plus: 0 %}
                   {% endif %}
                   
                   {% assign customtagfromDatetime = custom_tag_from_date[i] | append: " " | append: custom_tag_from_time[i] | date: "%Y-%m-%d %H:%M:%S" %}
                   {% assign customtagtoDatetime = custom_tag_to_date[i] | append: " " | append: custom_tag_to_time[i] | date: "%Y-%m-%d %H:%M:%S" %}
                   {% unless product_sold_out %}
                     {% if customtagfromDatetime <= currentDatetime and customtagtoDatetime >= currentDatetime and custom_tag_type[i] != 'blank' and product.available == true and custom_tag_type[i] != 'Sold Out' and custom_tag_type[i] != 'Low Stock' and custom_tag_type[i] != 'Sale'  %}
                       
                         <span class="custom_product_tags">{% if custom_tag_icon[i] %} <img src="{{ custom_tag_icon[i] }}" alt=""> {% endif %}<h5>{{ custom_tag_name[i] }} </h5></span> 
                        
                     {% endif %}
                   {% endunless %}
                   {% if custom_tag_type[i] != 'blank' and custom_tag_type[i] == 'Low Stock' and lowstock_inventory_limit != '' and product.available == true and product.first_available_variant.inventory_quantity <= lowstock_inventory_limit and low_stock_found == true %}
                     <span class="custom_product_tags"> {% if custom_tag_icon[i] %} <img src="{{ custom_tag_icon[i] }}" alt=""> {% endif %} <h5>{{ custom_tag_name[i] }} </h5></span> 
                   {% endif %}
             {% endif %}
            {% endfor %}
          </div>
          
          


          
        {%- comment -%}
          Live region for announcing updated price and availability to screen readers
        {%- endcomment -%}
        <p class="visually-hidden" data-product-status
          aria-live="polite"
          role="status"
        ></p>

        {%- comment -%}
          Live region for announcing that the product form has been submitted and the
          product is in the process being added to the cart
        {%- endcomment -%}
        <p class="visually-hidden" data-loader-status
          aria-live="assertive"
          role="alert"
          aria-hidden="true"
        >{{ 'products.product.loader_label' | t }}</p>

        <div
          class="product-single__store-availability-container"
          data-store-availability-container
          data-product-title="{{ product.title | escape }}"
          data-has-only-default-variant="{{ product.has_only_default_variant }}"
          data-base-url="{{ shop.url }}{{ routes.root_url }}"
        >
        </div>
        </div>
    </div>
</section>

{% unless product == empty %}
  <script type="application/json" id="ProductJson-{{ section.id }}">
    {{ product | json }}
  </script>
  <script type="application/json" id="ModelJson-{{ section.id }}">
    {{ product.media | where: 'media_type', 'model' | json }}
  </script>
{% endunless %}

{% if product.metafields.accentuate.video_url or product.metafields.accentuate.video_background %}
<section class="video-content wowo fadeInUp">
  <div class="medium-container">
    <a href="javascript:void(0);" class="video-link embed">
        <i class="play-video"></i>
        <div class="data-video">{{ product.metafields.accentuate.video_url }}</div>
        <div class="img-bg" style="background-image: url('{{ product.metafields.accentuate.video_background }}')"></div>
    </a>
  </div>
</section>
{% endif %}
  
{% if product.metafields.accentuate.content_product_info or product.metafields.accentuate.video_of_product or product.metafields.accentuate.title%}
<section class="video-text">
    <div class="left-box wowo fadeInUp">
        <div class="box">
            {{ product.metafields.accentuate.content_product_info }}
          	{% if product.metafields.accentuate.video_of_product %}
			<div class="video-link embed">
                <a href="javascript:void(0);" class="a-link">Watch the video</a>
                <div class="data-video">{{ product.metafields.accentuate.video_of_product }}</div>
            </div>
          	{% endif %}
        </div>
    </div>
  	{% if product.metafields.accentuate.title %}
    <div class="right-box wowo fadeInUp">
        <div class="box">
            <table>
              {% for title in  product.metafields.accentuate.title %}
              {% assign foo = forloop.index0 %}
              <tr>
                <td>{{ product.metafields.accentuate.title[foo] }}</td>
                <td>{{ product.metafields.accentuate.content[foo] }}</td>
              </tr>
              {% endfor %} 
            </table>
        </div>
    </div>
  	{% endif %}
</section>
{% endif %}
  
{% if product.metafields.accentuate.image_slider %}
<section class="slider-wrap wowo fadeInUp">
	<div class="product-slider">
    {% for image_slider in  product.metafields.accentuate.image_slider %}
    {% assign foo = forloop.index0 %}
      <div class="slider-list">
          <img src="{{ product.metafields.accentuate.image_slider[foo] }}">
      </div>
    {% endfor %}
   	</div>   
</section>
{% endif %}
  
</div>

<style>
  .product-form__item.qty-wrap{
    display:block!important;
  }
</style>
