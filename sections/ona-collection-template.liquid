<script>
  /* Bottomdescription "Read More" toggle. Inline <script> runs synchronously during
     HTML parsing — but theme.liquid loads jQuery with `defer`, so `jQuery` is not yet
     defined here. Wrap in DOMContentLoaded (defer scripts finish before DCL fires)
     so jQuery is guaranteed loaded by the time we run.
     Scoped to .bottomdescription so any other .readmore-text on the page is not affected.
     Idempotent: short-circuits if a .readMore is already next-sibling (defends against
     shopify:section:load re-runs and double-bind). */
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof jQuery === 'undefined') return;
    var $ = jQuery;
    var $rmText = $('.bottomdescription .readmore-text');
    if (!$rmText.length || $rmText.next('.readMore').length) return;
    $rmText.hide();
    $rmText.after('<a class="readMore" style="cursor:pointer;margin-top:12px;margin-bottom:12px;display:inline-block;background:#5b1129;color:#ffffff;padding:5px 15px;">Read More</a>');
    $('.bottomdescription').off('click.readmore').on('click.readmore', '.readMore', function () {
      var $btn = $(this);
      $btn.prev('.readmore-text').slideToggle(200, function () {
        $btn.text($btn.text() === 'Read More' ? 'Close' : 'Read More');
      });
      return false;
    });
  });
</script>

<script>
  /* ONA Product Card - Variant picker & AJAX Add to Cart
     Mirrors the functionality from ona-featured-collection.liquid */
  window.__onaAutoOpenCart = window.__onaAutoOpenCart || {{ settings.auto_open_cart_drawer | json }};

  (function () {
    function openCartDrawer() {
      var drawer = document.querySelector('cart-drawer-component');
      if (drawer && typeof drawer.open === 'function') { drawer.open(); return; }
      var trigger = document.querySelector('[data-testid="cart-drawer-trigger"]');
      trigger && trigger.click();
    }

    function initOnaCards() {
      document.querySelectorAll('.shop-list [data-ona-card]').forEach(function (card) {
        if (card.dataset.onaCardInit) return;
        card.dataset.onaCardInit = 'true';

        var pills = card.querySelectorAll('[data-card-pill]');
        var variantInput = card.querySelector('[data-card-variant-input]');
        var priceEl = card.querySelector('[data-card-price]');
        var optVal = card.querySelector('[data-card-opt-value]');
        var atc = card.querySelector('[data-card-atc]');
        var form = card.querySelector('[data-card-form]');

        if (!form || !atc) return;

        pills.forEach(function (pill) {
          pill.addEventListener('click', function (e) {
            e.preventDefault();
            e.stopPropagation();
            pills.forEach(function (p) {
              p.classList.remove('ona-pc__pill--active');
              p.setAttribute('aria-checked', 'false');
            });
            pill.classList.add('ona-pc__pill--active');
            pill.setAttribute('aria-checked', 'true');
            if (variantInput) variantInput.value = pill.dataset.variantId;
            if (optVal) optVal.textContent = pill.dataset.variantTitle;
            var available = pill.dataset.variantAvailable === 'true';
            atc.disabled = !available;
            atc.textContent = available ? 'Add to cart' : 'Sold out';
          });
        });

        form.addEventListener('submit', function (e) {
          e.preventDefault();
          atc.classList.add('is-loading');
          var label = atc.textContent;
          atc.textContent = 'Adding…';

          var body = new URLSearchParams();
          body.append('id', variantInput ? variantInput.value : '');
          body.append('quantity', '1');
          body.append('sections', 'ona_header');

          fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: body,
            credentials: 'same-origin'
          })
          .then(function (r) { return r.ok ? r.json() : r.json().then(function (err) { throw err; }); })
          .then(function (resp) {
            atc.textContent = 'Added ✓';

            document.dispatchEvent(new CustomEvent('cart:update', {
              bubbles: true,
              detail: {
                resource: resp,
                sourceId: variantInput ? variantInput.value : '',
                data: {
                  source: 'ona-collection-template',
                  sections: resp.sections || {},
                  itemCount: resp.item_count
                }
              }
            }));

            if (window.__onaAutoOpenCart) setTimeout(openCartDrawer, 120);
            setTimeout(function () { atc.textContent = label; atc.classList.remove('is-loading'); }, 1500);
          })
          .catch(function (err) {
            atc.textContent = (err && err.description) ? err.description : 'Error';
            atc.classList.remove('is-loading');
            setTimeout(function () { atc.textContent = label; }, 2000);
          });
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initOnaCards);
    } else {
      initOnaCards();
    }

    document.addEventListener('shopify:section:load', initOnaCards);
  })();
</script>

