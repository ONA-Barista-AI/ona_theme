/* BL-03: allow ATC + variant pills to flow below product info naturally */
.shop-list .list {
  flex-wrap: nowrap;
  margin-bottom: 30px;
}
.shop-list .list-box {
  height: auto;
  flex: 1 1 auto;
}

/* ONA Product Card - Variants & Add to Cart */
.ona-pc__actions {
  padding: 0 10px 15px;
  text-align: center;
}
.ona-pc__opt {
  margin-bottom: 12px;
}
.ona-pc__opt-label {
  display: block;
  font: 400 13px/1.4 'Karla', sans-serif;
  color: #333;
  margin-bottom: 6px;
}
.ona-pc__opt-label strong {
  font-weight: 400;
}
.ona-pc__opt-pills {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  justify-content: center;
}
.ona-pc__pill {
  padding: 6px 14px;
  border: 1px solid #ccc;
  background: #fff;
  font: 400 13px/1 'Karla', sans-serif;
  color: #2b2c30;
  cursor: pointer;
  transition: all 0.15s ease;
}
.ona-pc__pill:hover {
  border-color: #2b2c30;
}
.ona-pc__pill--active {
  background: #2b2c30;
  color: #fff;
  border-color: #2b2c30;
}
.ona-pc__pill--sold-out {
  opacity: 0.5;
  text-decoration: line-through;
}
.shop-list .list form[data-card-form] {
  display: flex;
  justify-content: center;
}
.ona-pc__atc {
  display: block;
  width: 100%;
  padding: 11px 12px;
  background: #2b2c30;
  color: #fff;
  border: 1px solid #2b2c30;
  cursor: pointer;
  font: 400 13px/1 'Karla', sans-serif;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  transition: background 0.2s ease, border-color 0.2s ease;
}
.ona-pc__atc:hover:not([disabled]) {
  background: #661a34;
  border-color: #661a34;
}
.ona-pc__atc[disabled] {
  background: #ccc;
  border-color: #ccc;
  cursor: not-allowed;
}
.ona-pc__atc.is-loading {
  opacity: 0.7;
  pointer-events: none;
}
/* Collection FAQs */
  .collection-faqs {
    margin-top: 3rem;
    margin-bottom: 3rem;
  }

  .collection-faqs__title {
    font-size: 1.6rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    text-align: left;
  }

  .collection-faqs__accordion {
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .collection-faqs__item {
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    padding: 0.75rem 0;
  }

  .collection-faqs__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    font-weight: 500;
  }

  .collection-faqs__question::-webkit-details-marker {
    display: none;
  }

  .collection-faqs__icon {
    margin-left: 1rem;
    font-size: 1.2rem;
  }

  .collection-faqs__answer {
    margin-top: 0.75rem;
    font-size: 0.95rem;
    line-height: 1.5;
  }

