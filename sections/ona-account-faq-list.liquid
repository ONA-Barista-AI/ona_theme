<div class="list">
  <h2>{{ section.settings.title2 }}</h2>
  <div class="accordion">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          <div class="accordion-list">
            <div class="accordion-title">{{ block.settings.title }} <i class="icon-close"></i></div>
            <div class="accordion-content">
             {{ block.settings.content }}
            </div>
          </div>
        {% endfor %}
      {% endif %} 
  </div>
</div>
{% schema %}
{
  "name": {
    "en": "Account FAQ list"
  },
  "settings": [
    {
      "type": "text",
      "id": "title2",
      "label": {
		"en": "Title"
      }
    }
  ],
  "blocks": [
    {
      "type": "block",
      "name": {
        "en": "Block"
      },
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": {
            "en": "Title"
          }
        },
        {
          "type": "richtext",
          "id": "content",
          "label": {
            "en": "Content"
          }
        }
      ]
    }
  ]
}
{% endschema %}
