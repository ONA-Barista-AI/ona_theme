{% schema %}
{
  "name": "ONA Divider",
  "tag": "section",
  "class": "custom-divider-section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Divider label (optional)",
      "default": "Divider"
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label font size (rem)",
      "min": 0.8,
      "max": 3,
      "step": 0.1,
      "default": 1.5
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label text colour",
      "default": "#000000"
    },
    {
      "type": "checkbox",
      "id": "show_line",
      "label": "Show divider line",
      "default": true
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Line colour",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "line_thickness",
      "label": "Line thickness (px)",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "line_width",
      "label": "Line width (%)",
      "min": 10,
      "max": 100,
      "step": 5,
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Custom Divider",
      "category": "Layout"
    }
  ]
}
{% endschema %}

<div
  class="custom-divider"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    text-align: center;
  "
>
  {% if section.settings.label != blank %}
    <p style="
      margin-bottom: 10px;
      font-weight: bold;
      font-size: {{ section.settings.label_size }}rem;
      color: {{ section.settings.label_color }};
    ">
      {{ section.settings.label }}
    </p>
  {% endif %}

  {% if section.settings.show_line %}
    <hr
      style="
        border: none;
        height: {{ section.settings.line_thickness }}px;
        background-color: {{ section.settings.line_color }};
        width: {{ section.settings.line_width }}%;
        margin: 0 auto;
      "
    >
  {% endif %}
</div>
