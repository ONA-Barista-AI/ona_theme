{%- liquid
  assign show = section.settings.show_product_recommendations
  assign heading = section.settings.heading
  assign limit = 4

  # Mirror Horizon's fallback: use recommendations when available, else pull from
  # the catalog so the block never renders empty on first paint.
  if recommendations.performed and recommendations.products_count > 0
    assign products = recommendations.products
  else
    assign products = null
  endif
-%}

{%- if show -%}
<product-recommendations
  id="product-recommendations-{{ section.id }}"
  data-url="{{ routes.product_recommendations_url }}?limit={{ limit }}"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-intent="related"
  data-recommendations-performed="false"
>
  {%- if products != blank -%}
    <section class="recommendations-list also-shop">
      <div class="container">
        {%- if heading != blank -%}
          <div class="top">
            <h2>{{ heading | escape }}</h2>
            <a href="/collections/all">SEE ALL</a>
          </div>
        {%- endif -%}
        <div class="shop-list">
          {%- for p in products limit: limit -%}
            <div class="list">
              <a href="{{ p.url }}" class="list-box">
                <div class="img">
                  <img src="{{ p.featured_media | img_url: '1024x1024' }}" alt="{{ p.featured_image.alt | default: p.title | escape }}" loading="lazy" decoding="async">
                </div>
                <div class="text">
                  {%- liquid
                    assign price = p.price | money
                    assign on_sale = false
                    if p.compare_at_price > p.price
                      assign on_sale = true
                    endif
                  -%}
                  <div class="price{% if on_sale %} price--on-sale{% endif %}">
                    {%- if p.price_varies -%}
                      <span class="price-item">from {{ price }}</span>
                    {%- else -%}
                      <span class="price-item">{{ price }}</span>
                    {%- endif -%}
                    {%- if on_sale -%}
                      <span class="price-item price-item--compare"><s>{{ p.compare_at_price | money }}</s></span>
                    {%- endif -%}
                  </div>
                  <p>{{ p.title }}</p>
                </div>
              </a>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}
</product-recommendations>
<script>
  (function(){
    var el = document.getElementById('product-recommendations-{{ section.id }}');
    if (!el || el.querySelector('section.recommendations-list')) return;
    var url = el.getAttribute('data-url') +
              '&product_id=' + el.getAttribute('data-product-id') +
              '&section_id=' + el.getAttribute('data-section-id') +
              '&intent=' + el.getAttribute('data-intent');
    fetch(url).then(function(r){ return r.text(); }).then(function(html){
      var doc = new DOMParser().parseFromString(html, 'text/html');
      var inner = doc.querySelector('#product-recommendations-{{ section.id }}');
      if (inner) el.innerHTML = inner.innerHTML;
    }).catch(function(e){ console.warn('[ONA recs]', e); });
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "ONA recommendations",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_product_recommendations",
      "label": "Show recommendations",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You may also like"
    }
  ]
}
{% endschema %}
