<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- comment -%} R13 Perf P2 — early DNS/TCP for known third-party hosts {%- endcomment -%}
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    <link rel="dns-prefetch" href="https://cdnjs.cloudflare.com">
    <link rel="dns-prefetch" href="https://static.klaviyo.com">
    <link rel="dns-prefetch" href="https://static-tracking.klaviyo.com">
    <link rel="dns-prefetch" href="https://cdn.judge.me">

    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}
    {%- if settings.apple_touch_icon != blank -%}
      <link
        rel="apple-touch-icon"
        href="{{ settings.apple_touch_icon | image_url: width: 180, height: 180 }}"
      >
    {%- elsif settings.favicon != blank -%}
      <link
        rel="apple-touch-icon"
        href="{{ settings.favicon | image_url: width: 180, height: 180 }}"
      >
    {%- endif -%}

    {% # theme-check-disable RemoteAsset %}
    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}
    {{ 'ona-brand.css' | asset_url | stylesheet_tag }}
    {%- comment -%} R45 / Phase A3: bootstrap.min.css (~160K raw / ~32K gzipped) replaced by 5 hand-rolled utilities (.container, .row, .btn, .form-group, .input-group) appended to main.css R45 block. 0 .col-*, 0 .d-*, 0 .m-/.p-, 0 .btn-*, 0 .modal/.navbar/.dropdown/.carousel uses found in dev (post-grep audit). bootstrap.min.css file kept in assets/ as cold backup; uncomment line below to roll back if any third-party app breaks. {%- endcomment -%}
    {%- comment -%} {{ 'bootstrap.min.css' | asset_url | stylesheet_tag }} {%- endcomment -%}
    {{ 'slick.css' | asset_url | stylesheet_tag }}
    {%- comment -%}
      R28 — main.css -> main.min.css (csso minified)
      R30 — style.css + ona-fixes.css merged into the tail of main.css.
            Source files kept as cold backups; their two stylesheet_tag
            entries removed here, saving 2 HTTP requests and 2
            render-blocking resources.
    {%- endcomment -%}
    {{ 'main.min.css' | asset_url | stylesheet_tag }}
    {%- comment -%} Disable WOW / fadeInUp scroll animations site-wide — keep markup intact, just nullify the effect. {%- endcomment -%}
    <style>
      .wowo, .wowo.animated,
      .fadeIn, .fadeInUp, .fadeInup, .fadeInDown, .fadeInLeft, .zoomOut, .heartBeat,
      .animate__fadeIn, .animate__fadeInUp, .animate__fadeInDown {
        opacity: 1 !important;
        animation: none !important;
        transform: none !important;
      }
    </style>
    <script src="{{ 'jquery-3.7.1.min.js' | asset_url }}" defer></script>
    {%- comment -%} R49 / Phase B1: jQuery 2.0.3 (unminified, 242K) -> 3.7.1 (minified, 87K). Audit (2026-04-29) found 0 breaking-change call sites in script.js + sections + snippets (no .size/.live/.andSelf/$.browser/etc.). slick.js bundled is 1.8.0 which is officially jQuery 3 compatible. -154K raw / ~-30K gzipped transfer. {%- endcomment -%}
    {%- comment -%} R44 / Phase A1: jquery.cookie.js removed. Cookie read/write now provided by an inline mini impl inside onaEnsureJqStubs() in script.js (see L33). 1 fewer HTTP request, -3K transfer. {%- endcomment -%}
    <script src="{{ 'TweenMax.min.js' | asset_url }}" defer></script>
    <script src="{{ 'MorphSVGPlugin.min.js' | asset_url }}" defer></script>
    <script src="{{ 'imagesloaded.pkgd.min.js' | asset_url }}" defer></script>
    <script src="{{ 'slick.min.js' | asset_url }}" defer></script>
    {%- comment -%} R50: slick.js (87K) -> slick.min.js (47K, terser --compress drop_console=true, NO mangle per R38 lesson #46). slick.js kept as cold backup in assets/. {%- endcomment -%}
    {%- comment -%} R44 / Phase A2: WOW.js CDN removed. Replaced by IntersectionObserver IIFE at top of script.js + @keyframes in main.css R44 block. 1 fewer CDN request, ~10K transfer saved, plus removes a top-level new WOW() failure mode (#12). {%- endcomment -%}
    <script src="https://www.youtube.com/iframe_api" defer></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.matchHeight/0.7.2/jquery.matchHeight-min.js" defer></script>
    {%- comment -%} R38: terser-compressed script.js (82K → 48K, -41%, drop_console=true, NO mangle). The full-mangle version caused PC nav hover lag (2026-04-28). {%- endcomment -%}
    <script src="{{ 'script.min.js' | asset_url }}" defer></script>

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
    {% # theme-check-enable RemoteAsset %}
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}{% if template contains 'wholesale' %} template-wholesale{% endif %}{% if template.name == 'index' %} template-index{% endif %}{% if template.name == 'cart' %} template-cart{% endif %}{% if template.name == 'search' %} template-search{% endif %}{% if template.name == '404' %} template-404{% endif %}{% if template.name == 'blog' %} template-blog{% endif %}{% if template.name == 'article' %} template-article{% endif %}{% if template.name == 'page' and page.handle != blank %} page-{{ page.handle }}{% endif %}{% if template contains 'wholesale' %} inner-page{% endif %}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    {%- render 'ona-toolbar' -%}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script>
      // Inline header height and menu style calculations to prevent layout shift
      // Note: Updates in calculateHeaderGroupHeight(), updateTransparentHeaderOffset() and setHeaderMenuStyle() utilities.js should be kept in sync with this function
      (function setHeaderHeighCustomProperties() {
        /*
         * Header calculation functions for maintaining CSS variables
         * Mimic calculateHeaderGroupHeight() in utilities.js
         */
        const header = document.querySelector('header-component');
        const headerGroup = document.querySelector('#header-group');
        const hasHeaderSection = headerGroup?.querySelector('.header-section');

        if (!header || !headerGroup) return;

        const headerTopRow = header.querySelector('.header__row--top');
        const headerHeight = header.offsetHeight;

        // Calculate the total height of the header group
        let headerGroupHeight = 0;
        const children = headerGroup.children;
        for (let i = 0; i < children.length; i++) {
          const element = children[i];
          if (element === header || !(element instanceof HTMLElement)) continue;
          headerGroupHeight += element.offsetHeight;
        }

        // Check for transparent header special case
        if (header.hasAttribute('transparent') && header.parentElement?.nextElementSibling) {
          headerGroupHeight += headerHeight;
        }

        // Set CSS variables
        document.body.style.setProperty('--header-height', `${headerHeight}px`);
        document.body.style.setProperty('--header-group-height', `${headerGroupHeight}px`);

        if (headerTopRow) {
          window.requestAnimationFrame(function () {
            document.body.style.setProperty('--top-row-height', `${headerTopRow.offsetHeight}px`);
          });
        }

        /**
         * Updates CSS custom properties for transparent header offset calculation
         * Mimic updateTransparentHeaderOffset() in utilities.js
         */

        if (!hasHeaderSection || !header?.hasAttribute('transparent')) {
          document.body.style.setProperty('--transparent-header-offset-boolean', '0');
          return;
        }

        const hasImmediateSection = hasHeaderSection.nextElementSibling?.classList.contains('shopify-section');

        const shouldApplyOffset = !hasImmediateSection ? '1' : '0';
        document.body.style.setProperty('--transparent-header-offset-boolean', shouldApplyOffset);
      })();

      (function setHeaderMenuStyle() {
        const headerComponent = document.querySelector('#header-component');
        if (headerComponent) {
          const isTouchDevice = 'ontouchstart' in window && navigator.maxTouchPoints > 0;
          const overflowList = headerComponent?.querySelector('overflow-list');
          const hasReachedMinimum = overflowList && overflowList.hasAttribute('minimum-reached');
          headerComponent.dataset.menuStyle = isTouchDevice || hasReachedMinimum ? 'drawer' : 'menu';
        }
      })();
    </script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {%- if template == 'index' -%}
        <h1 class="visually-hidden">{{ shop.name }}</h1>
      {%- endif -%}
      {{ content_for_layout }}
    </main>

    <footer>
      {% sections 'footer-group' %}
    </footer>

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}
  </body>
</html>
