    top: 15px;
    -webkit-transform: rotate(-45deg);
    transform: rotate(-45deg)
}

.hamburger.active span:nth-child(2) {
    background: transparent !important
}

.hamburger.active span:last-child {
    top: 15px;
    -webkit-transform: rotate(45deg);
    transform: rotate(45deg)
}

