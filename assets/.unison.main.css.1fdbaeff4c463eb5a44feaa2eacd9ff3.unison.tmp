.pop-up-form {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1000;
    padding: 0 70px;
    display: none
}

@media (max-width:1199.98px) {
    .pop-up-form {
        padding: 0 50px
    }
}

@media (max-width:991.98px) {
    .pop-up-form {
        padding: 0 30px
    }
}

.pop-up-form:before {
    content: "";
    width: 100%;
    height: 100%;
    background: rgba(56, 8, 24, 0.75);
    position: absolute;
    top: 0;
    left: 0
}

.pop-up-form.up .form-box {
    top: 0;
    opacity: 1;
    visibility: visible
}

.pop-up-form .form-box {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 64px;
    left: 0;
    opacity: 0;
    visibility: hidden;
    -webkit-transition: All 0.4s ease-in-out;
    transition: All 0.4s ease-in-out
}

.pop-up-form .form-box .box {
    position: absolute;
    top: 64px;
    bottom: 38px;
    left: 50%;
    -webkit-transform: translateX(-50%);
    transform: translateX(-50%);
    max-width: 1300px;
    width: calc(100% - 140px);
    z-index: 10;
    overflow: auto;
    padding: 72px 161px 20px 111px;
    background: #ffffff
}

@media (max-width:1199.98px) {
    .pop-up-form .form-box .box {
        width: calc(100% - 100px);
        padding: 62px 70px 20px 70px
    }
}

@media (max-width:991.98px) {
    .pop-up-form .form-box .box {
        width: calc(100% - 60px);
        padding: 52px 50px 20px 50px
    }
}

@media (max-width:767.98px) {
    .pop-up-form .form-box .box {
        padding: 52px 30px 30px 30px
    }
}

@media (max-width:575.98px) {
    .pop-up-form .form-box .box {
        top: 30px;
        bottom: 30px;
        padding: 52px 20px 30px 20px
    }
}

.pop-up-form .form-box .pop-up-form-close {
    position: absolute;
    top: 42px;
    right: 43px;
    font-size: 20px;
    z-index: 10
}

@media (max-width:767.98px) {
    .pop-up-form .form-box .pop-up-form-close {
        top: 32px;
        right: 30px
    }
}

@media (max-width:575.98px) {
    .pop-up-form .form-box .pop-up-form-close {
        top: 25px;
        right: 20px
    }
}

.pop-up-form .form-box .pop-up-form-close:before {
    color: #861f41
}

.pop-up-form .form-box .pop-up-form-close:hover {
    -webkit-transform: scale(1.1);
    transform: scale(1.1)
}

