<section class="two-columns-image">
  <div class="container">
    <div class="content wowo fadeInUp">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          <div class="list">
            <a href="{{ block.settings.url }}" class="list-box">
              <div class="img-bg" style="background-image: url('{{ block.settings.image | img_url: '1270x' }}')"></div>
              <h2>{{ block.settings.title }}</h2>
            </a>
          </div>
        {% endfor %}
      {% endif %} 
    </div>
  </div>
</section>
{% schema %}
{
  "name": {
    "en": "Two Images"
  },
  "max_blocks": 2,
  "blocks": [
    {
      "type": "block",
      "name": {
        "en": "Block"
      },
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": {
            "en": "Image"
          }
        },
        {
          "type": "text",
          "id": "title",
          "label": {
            "en": "Title"
          }
        },
        {
          "type": "url",
          "id": "url",
          "label": {
            "en": "Button url"
          }
        }
      ]
    }
  ],
  "presets": [
    {
      "name": {
        "en": "Two Images"
      },
      "category": {
        "en": "Image"
      }
    }
  ]
}
{% endschema %}