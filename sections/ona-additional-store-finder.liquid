 <section class="store-finder store-finder-add" data-id="store-finder-content">
    <div class="container">
        <div class="top">
            <div class="left">
                <h2>Store finder</h2>
                <ul class="state">
                    <li class="all-state"><a href="#" data-state="all">All</a></li>
                    <li class="act-state"><a href="#" data-state="ACT">ACT</a></li>
                    <li class="nsw-state"><a href="#" data-state="NSW">NSW</a></li>
                    <li class="qld-state"><a href="#" data-state="QLD">QLD</a></li>
                    <li class="sa-state"><a href="#" data-state="SA">SA</a></li>
                    <li class="wa-state"><a href="#" data-state="WA">WA</a></li>
                    <li class="nt-state"><a href="#" data-state="NT">NT</a></li>
                    <li class="tas-state"><a href="#" data-state="TAS">TAS</a></li>
                    <li class="vic-state"><a href="#" data-state="VIC">VIC</a></li>
                </ul>
            </div>
            <div class="right">
                <div class="form">
                    <div id="the-basics" class="form-group country-input  typeahead__container result">
                        <input id="pac-input" class="controls" type="text" placeholder="Enter your suburb" />
                    </div>
                </div>
            </div>
        </div>
        <div class="content">
          	<div class="no-store" style="display:none;">
              <p>"Oops, there are no stores near the location you've searched. <br><button class="get-current-location">Click here</button> to search for a store near your current location.</p>
          	</div>
            <div class="store-list left" style="overflow: hidden;">
                <div class="address-box mCustomScrollbar">
                    <div class="list">
                    </div>
                </div>
                <div class="address-all">
                    <div class="list">
                        <ul class="addr">
                          {% if section.blocks.size > 0 %}
                            {% for block in section.blocks %}
                            <li data-state="{{ block.settings.state }}" data-area="{{ block.settings.suburb }}" class="row">
                                <div data-la="{{ block.settings.latitude }}" data-lo="{{ block.settings.longitude }}" data-state="{{ block.settings.state }}" data-area="{{ block.settings.suburb }}" class="addr-list">
                                    {{ block.settings.title }}
                                    <div class="map-content">
                                        <div class="lists">
                                            <div class="text">
												<h3>{{ block.settings.title }}</h3>
                                                <i class="icon-close"></i>
                                                <div class="bottom">
                                                    <div class="left">
                                                        <p>{{ block.settings.storeaddress }}</p>
                                                        {% if block.settings.storeaddressurl %} 
                                                      		<p><a target="_blank" href="{{ block.settings.storeaddressurl }}" class="a-btn">Website</a></p> 
                                                      		{% else %}
                                                      		<p></p>
                                                      	{% endif %} 
                                                    </div>
                                                    <div class="right">
                                                      {{ block.settings.time }}
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </li>
                            {% endfor %}
                          {% endif %} 
						</ul>
                    </div>
                </div>
            </div>
            <div class="map" id="map"></div>
