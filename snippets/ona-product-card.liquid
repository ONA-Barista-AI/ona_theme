{%- comment -%}
  Product card matching the collection page layout.
  Usage: {% render 'ona-product-card', product: product %}
{%- endcomment -%}
{%- if product.handle != 'ona-tote' -%}
{%- assign v0 = product.selected_or_first_available_variant -%}
<div class="list wowo fadeInUp" data-ona-card data-product-id="{{ product.id }}">
  <a href="{{ product.url }}" class="list-box">
    <div class="img">
      <img src="{{ product.featured_media | img_url: '1024x1024' }}" alt="{{ product.featured_image.alt | default: product.title | escape }}">
    </div>

    <div class="text">
      {% assign custom_tag_status = product.metafields.custom_product.tag_status %}
      {% assign custom_tag_name = product.metafields.custom_product.tag_name.value %}
      {% assign custom_tag_color = product.metafields.custom_product.tag_color %}
      {% assign custom_tag_icon = product.metafields.custom_product.tag_icon %}
      {% assign custom_tag_low_stock_qty = product.metafields.custom_product.lowstock_inventory %}
      {% assign custom_tag_from_date = product.metafields.custom_product.from_date %}
      {% assign custom_tag_from_time = product.metafields.custom_product.from_time %}
      {% assign custom_tag_to_date = product.metafields.custom_product.to_date %}
      {% assign custom_tag_to_time = product.metafields.custom_product.to_time %}
      {% assign currentDatetime = "now" | date: "%Y-%m-%d %H:%M:%S" %}
      {% assign custom_tag_type = product.metafields.custom_product.tag_type %}
      {% if custom_tag_status != blank %}
        {% assign total_instances = custom_tag_status.size %}
      {% else %}
        {% assign total_instances = 0 %}
      {% endif %}

      {% assign low_stock_found = false %}
      {% assign product_sold_out = false %}
      {% assign product_sale_tag = false %}

      {% if custom_tag_type contains 'Sale' %}
        {% assign product_sale_tag = false %}
      {% endif %}

      {% assign lowstock_index = '' %}
      {% assign lowstock_status = '' %}
      {% assign is_lowstock_and_active = false %}
      {% assign soldstock_index = '' %}
      {% assign soldstock_status = '' %}
      {% assign is_soldstock_and_active = false %}

      {% for tagtype in custom_tag_type %}
        {% if tagtype == 'Low Stock' %}{% assign lowstock_index = forloop.index0 %}{% endif %}
        {% if tagtype == 'Sold Out' %}{% assign soldstock_index = forloop.index0 %}{% endif %}
      {% endfor %}
      {% if lowstock_index != '' or soldstock_index != '' %}
        {% for tagstatus in custom_tag_status %}
          {% if forloop.index0 == lowstock_index %}{% assign lowstock_status = tagstatus %}{% endif %}
          {% if lowstock_status == 'Active' %}{% assign is_lowstock_and_active = true %}{% endif %}
          {% if forloop.index0 == soldstock_index %}{% assign soldstock_status = tagstatus %}{% endif %}
          {% if soldstock_status == 'Active' %}{% assign is_soldstock_and_active = true %}{% endif %}
        {% endfor %}
        {% for taglowstock in custom_tag_low_stock_qty %}
          {% if forloop.index0 == lowstock_index %}{% assign lowstock_inventqty = taglowstock | plus: 0 %}{% endif %}
        {% endfor %}
      {% endif %}

      {% if custom_tag_type contains 'Low Stock' and product.first_available_variant.inventory_quantity <= lowstock_inventqty and is_lowstock_and_active == true %}
        {% assign low_stock_found = true %}
      {% endif %}
      {% if custom_tag_type contains 'Sold Out' and product.available == false and is_soldstock_and_active == true %}
        {% assign product_sold_out = true %}
      {% endif %}

      {% for i in (0..total_instances) %}
        {% if custom_tag_status[i] != 'Disable' %}
          {% if custom_tag_low_stock_qty[i] != '' %}
            {% assign lowstock_inventory_limit = custom_tag_low_stock_qty[i] | plus: 0 %}
          {% endif %}
          {% assign customtagfromDatetime = custom_tag_from_date[i] | append: " " | append: custom_tag_from_time[i] | date: "%Y-%m-%d %H:%M:%S" %}
          {% assign customtagtoDatetime = custom_tag_to_date[i] | append: " " | append: custom_tag_to_time[i] | date: "%Y-%m-%d %H:%M:%S" %}
          {% unless product_sold_out %}
            {% if customtagfromDatetime <= currentDatetime and customtagtoDatetime >= currentDatetime and custom_tag_type[i] != 'blank' and product.available == true and custom_tag_type[i] != 'Sold Out' and custom_tag_type[i] != 'Low Stock' and custom_tag_type[i] != 'Sale' %}
              <span class="custom_product_tags">{% if custom_tag_icon[i] %}<img src="{{ custom_tag_icon[i] }}" alt="">{% endif %}<h5{% if custom_tag_color[i] %} style="color:{{ custom_tag_color[i] }}"{% endif %}>{{ custom_tag_name[i] }}</h5></span>
            {% endif %}
          {% endunless %}

          {% if custom_tag_type[i] != 'blank' and custom_tag_type[i] == 'Low Stock' and lowstock_inventory_limit != '' and product.available == true and product.first_available_variant.inventory_quantity <= lowstock_inventory_limit and low_stock_found == true %}
            <span class="custom_product_tags">{% if custom_tag_icon[i] %}<img src="{{ custom_tag_icon[i] }}" alt="">{% endif %}<h5{% if custom_tag_color[i] %} style="color:{{ custom_tag_color[i] }}"{% endif %}>{{ custom_tag_name[i] }}</h5></span>
          {% elsif custom_tag_type[i] != 'blank' and custom_tag_type[i] == 'Sold Out' and product.available == false and product_sold_out == true %}
            <span class="custom_product_tags">{% if custom_tag_icon[i] %}<img src="{{ custom_tag_icon[i] }}" alt="">{% endif %}<h5{% if custom_tag_color[i] %} style="color:{{ custom_tag_color[i] }}"{% endif %}>{{ custom_tag_name[i] }}</h5></span>
          {% endif %}
        {% endif %}
      {% endfor %}
      {% if total_instances == 0 or product_sold_out == false %}
        {% if product.metafields.custom.sold_out.value == true or product.available == false %}
          <span class="custom_product_tags"><img src="https://cdn.shopify.com/s/files/1/0464/4824/6934/files/sold-out.png?v=1720094140" alt="sold out"><h5 style="color:#999999;">Sold Out - Online</h5></span>
        {% endif %}
      {% endif %}

      {%- liquid
        assign price = product.price | money
        assign compare_at_price = product.compare_at_price
        assign on_sale = false
        if compare_at_price > product.price
          assign on_sale = true
        endif
      -%}
      <div class="price{% if on_sale %} price--on-sale{% endif %}">
        {%- if product.price_varies -%}
          <span class="price-item" data-card-price>{{ 'products.product.from_lowest_price_html' | t: lowest_price: price }}</span>
        {%- else -%}
          <span class="price-item" data-card-price>{{ v0.price | money }}</span>
        {%- endif -%}
        {%- if on_sale -%}
          <span class="price-item price-item--compare"><s>{{ compare_at_price | money }}</s></span>
        {%- endif -%}
      </div>
      <p>{{ product.title }}</p>
    </div>
  </a>

  <div class="add-to-cart ona-pc__actions">
    {%- if product.variants.size > 1 and product.options.size == 1 -%}
      {%- assign opt_name = product.options.first -%}
      <div class="ona-pc__opt">
        <span class="ona-pc__opt-label">{{ opt_name }}: <strong data-card-opt-value>{{ v0.title }}</strong></span>
        <div class="ona-pc__opt-pills" role="radiogroup" aria-label="{{ opt_name }}">
          {%- for var in product.variants -%}
            <button type="button"
                    class="ona-pc__pill{% if var.id == v0.id %} ona-pc__pill--active{% endif %}{% unless var.available %} ona-pc__pill--sold-out{% endunless %}"
                    data-card-pill
                    data-variant-id="{{ var.id }}"
                    data-variant-title="{{ var.title | escape }}"
                    data-variant-price="{{ var.price | money }}"
                    data-variant-available="{{ var.available }}"
                    role="radio"
                    aria-checked="{% if var.id == v0.id %}true{% else %}false{% endif %}">
              {{- var.title -}}
            </button>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    <form action="{{ routes.cart_add_url }}" method="post" data-card-form>
      <input type="hidden" name="id" value="{{ v0.id }}" data-card-variant-input>
      <input type="hidden" name="quantity" value="1">
      <button type="submit" class="ona-pc__atc"{% unless v0.available %} disabled{% endunless %} data-card-atc>
        {%- if v0.available -%}Add to cart{%- else -%}Sold out{%- endif -%}
      </button>
    </form>
  </div>
</div>
{%- endif -%}
