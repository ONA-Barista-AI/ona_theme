        <div class="bg-box">
          {% if section.settings.bgtype == 'image' %}
          <div class="image-box" style="background-image:url('{{ section.settings.image | img_url: '1270x'  }}');"></div>
          {% else %}
          <div class="video-box">
            <video class="video-pc" muted="muted" autoplay="autoplay" loop="loop">
              <source src="{{section.settings.video.sources[1].url}}" type="video/mp4" >
            </video>
          </div>
          {% endif %}
          <div class="text-box">
            <h2>{{ section.settings.banner_text }}</h2>
          </div>
        </div>
      </div>

      {% endif %}
      {% if limit < collection.products_count %}
        {% if paginate.current_page == paginate.pages %}
          <p class="results">SHOWING {{ collection.products_count | modulo: limit }} OF {{ collection.products_count }} RESULTS</p>
        {% else %}
          <p class="results">SHOWING {{limit}} OF {{ collection.products_count }} RESULTS</p>
        {% endif %}
      {% else %}
        <p class="results">SHOWING ALL {{ collection.products_count }} RESULTS</p>
      {% endif %}
      
      <div class="sort-by">

        <div class="filters-toolbar__item-child">
          {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
          <label class="filters-toolbar__label select-label" for="SortBy">{{ 'collections.sorting.title' | t }}</label>
          <div class="filters-toolbar__input-wrapper select-group">
            <select name="sort_by" id="SortBy"
                    class="filters-toolbar__input"
                    aria-describedby="a11y-refresh-page-message a11y-selection-message"
                    data-default-sortby="{{ collection.default_sort_by }}"
                    data-select-input
                    >
              {%- for option in collection.sort_options -%}
              <option value="{{ option.value }}" {% if option.value == sort_by %}selected="selected"{% endif %}>{{ option.name }}</option>
              {%- endfor -%}
            </select>
            {% include 'icon-chevron-down' %}
          </div>
        </div>

      </div>
      <script>
        (function(){
          var sel = document.getElementById('SortBy');
          if (!sel) return;
          sel.addEventListener('change', function(){
            var url = new URL(window.location.href);
            url.searchParams.set('sort_by', sel.value);
            url.searchParams.delete('page');
            window.location.href = url.toString();
          });
        })();
      </script>
    </div>
    <div class="shop-filter">
