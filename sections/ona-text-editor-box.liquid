<section class="editor-box">
  <div class="container">
    <div class="content">
      <div class="wowo fadeInUp">
        {% if section.settings.body != blank %}
          {{ section.settings.body }}
        {% elsif page.content.size > 0 %}
          {{ page.content }}
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editor box",
  "settings": [
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "info": "Leave blank to fall back to page content"
    }
  ],
  "presets": [
    { "name": "Editor box", "category": "Text" }
  ]
}
{% endschema %}
