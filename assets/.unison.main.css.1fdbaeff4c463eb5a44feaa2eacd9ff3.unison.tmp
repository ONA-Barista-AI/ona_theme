[class*=" icon-"],
[class^=icon-] {
    font-family: "icomoon" !important;
    speak: never;
    font-style: normal;
    font-weight: normal;
    font-variant: normal;
    text-transform: none;
    line-height: 1;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale
}

.icon-arrow-white:before {
    content: "\e909"
}

.icon-arrow:before {
    content: "\e900"
}

.icon-close:before {
    content: "\e901"
}

