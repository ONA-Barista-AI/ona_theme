  }
  .ona-sf__iw-addr span { flex: 1; }
  .ona-sf__iw-hours {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font: 14px/1.5 'Karla', sans-serif;
    color: #555;
    margin-bottom: 12px;
  }
  .ona-sf__iw-hours-text,
  .ona-sf__iw-hours-text p,
  .ona-sf__iw-hours-text div { font: 14px/1.5 'Karla', sans-serif; margin: 0; color: #555; }
  .ona-sf__iw-icon {
    flex-shrink: 0;
    margin-top: 4px;
    color: #661a34;
  }
  .ona-sf__iw-btn {
    display: inline-block;
    padding: 8px 14px;
    background: #661a34;
    color: #fff;
    text-decoration: none;
    font: 12px 'Karla', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    margin-top: 4px;
  }
  .ona-sf__iw-btn:hover,
  .ona-sf__iw-btn:focus,
  .ona-sf__iw-btn:focus-visible,
  .ona-sf__iw-btn:active {
    background: #2b2c30 !important;
    color: #fff !important;
    text-decoration: none;
  }
  .ona-sf__iw-btn--secondary {
    background: transparent;
    color: #2b2c30;
    border: 1px solid #2b2c30;
  }
  .ona-sf__iw-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }
  @media (max-width: 999px) {
    .ona-sf__layout[data-view="map"] {
      grid-template-columns: 1fr;
      display: flex;
      flex-direction: column;
    }
    /* Mobile map view: map on top, list below with pagination */
    .ona-sf__layout[data-view="map"] .ona-sf__map-wrap {
      display: block;
      position: static;
      width: 100%;
      height: 50vh;
      min-height: 320px;
      max-height: 50vh;
      order: 1;
      overflow: hidden;
    }
    .ona-sf__layout[data-view="map"] .ona-sf__map {
      width: 100% !important;
      height: 100% !important;
      min-height: 0 !important;
    }
    .ona-sf__layout[data-view="map"] .ona-sf__list-wrap {
      width: 100%;
      height: auto !important;
      max-height: none !important;
      min-height: 0 !important;
      order: 2;
      margin-top: 16px;
    }
    .ona-sf__layout[data-view="map"] .ona-sf__list-wrap > .ona-sf__list,
    .ona-sf__layout[data-view="map"] .ona-sf__list {
      display: grid;
      width: 100%;
      height: auto;
      max-height: none;
      min-height: 0;
      overflow: visible;
      padding-right: 0;
    }
    /* Hide custom scrollbar on mobile — list flows naturally */
    .ona-sf__layout[data-view="map"] .ona-sf__scrollbar { display: none !important; }
    /* Map view on mobile uses page scroll, not pagination */
    .ona-sf__layout[data-view="map"] .ona-sf__pagination { display: none !important; }
    /* Tablet (700-999px): 2 columns in list view */
    .ona-sf__list { width: 100%; grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 699px) {
    /* Phone: single column for list, and stack search + button vertically */
    .ona-sf__list { grid-template-columns: 1fr; }
    .ona-sf__searchbar { flex-direction: column; gap: 10px; }
    .ona-sf__search-wrap { width: 100%; }
    .ona-sf__search { border-right: 1px solid #9e9f9b; }
    .ona-sf__near-me { width: 100%; justify-content: center; }
  }
  @media (max-width: 749px) {
    .ona-sf { padding: 0 0 50px; }
  }
