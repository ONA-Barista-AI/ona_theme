            function zoomOut(){}
            function MyMarker(map, number,options) {
              this.latlng = options.latlng;
              this.labelText = options.labelText || number+1;
              this.labelClass = options.labelClass || 'innerbox';
              this.clickFun = options.clickFun ;
              this.map_ = map;
              this.div_ = null;
              this.setMap(map);
              this.number= number;
            }
            MyMarker.prototype = new google.maps.OverlayView();
            MyMarker.prototype.onAdd = function() {
              var div = document.createElement('div');
              div.className="addedmark addedmark_"+this.number;
              div.style.border = "none";
              div.style.borderWidth = "0px";
              div.style.position = "absolute";
              div.style.cursor = "pointer";
             // div.id = "newDiv"
              div.setAttribute("data-index", this.number);
              div.onclick = this.clickFun ||function(){};
              div.onclick = function(e){
                e.stopPropagation();
                var index = jQuery(this).index() - 1;
                var myindex = jQuery(this).attr('data-index');
              
                jQuery(this).addClass('opacity on').siblings().removeClass('opacity on');
                var loc_id = '#map_item_'+myindex;
                var html = jQuery('.store-finder-add .address-box .list .addr-list').eq(index - 1).find('.map-content').html();
                //var html = jQuery(loc_id).find('.map-content').html(); 
                jQuery('.addedmark').find('.lists').remove();
                jQuery(this).children('.innerbox').append(html);

                //var la = jQuery('.store-finder-add .address-box .list .addr-list').eq(index).attr('data-la');
                //var lo = jQuery('.store-finder-add .address-box .list .addr-list').eq(index).attr('data-lo');
                var la = jQuery(loc_id).attr('data-la');
                var lo = jQuery(loc_id).attr('data-lo');
                map.panTo(new google.maps.LatLng(la, lo));
               
                if(map.getZoom()<9){
                  map.setZoom(9);
                }
              };
              var label = document.createElement('div');
              label.className = this.labelClass;
              label.style.position = 'absolute';

              var close = document.createElement('div');
              close.className = 'close-btn';
              close.innerHTML = 'x';
              close.onclick = this.clickFun ||function(){};
              close.onclick = function(e){
                e.stopPropagation();
                jQuery(this).parents('.addedmark').removeClass('on');
              };

              div.appendChild(label);
              label.appendChild(close);

              this.div_ = div;
              var panes = this.getPanes();
              panes.overlayMouseTarget.appendChild(div);
            }
            MyMarker.prototype.draw = function() {
              var overlayProjection = this.getProjection();
              var position = overlayProjection.fromLatLngToDivPixel(this.latlng);
              var div = this.div_;
              div.style.left =position.x - 10 + 'px';
              div.style.top  =position.y - 20 + 'px';
              div.style.width = '19px';
              div.style.height ='26px';
            }
            MyMarker.prototype.onRemove = function() {
              this.div_.parentNode.removeChild(this.div_);
              this.div_ = null;
            }
            MyMarker.prototype.hide = function() {
              if (this.div_) {
                this.div_.style.visibility = "hidden";
              }
            }
            MyMarker.prototype.show = function() {
              if (this.div_) {
                this.div_.style.visibility = "visible";
              }
            }
            MyMarker.prototype.toggle = function() {
              if (this.div_) {
                if (this.div_.style.visibility == "hidden") {
                  this.show();
                } else {
                  this.hide();
                }
              }
            }


            jQuery("#the-basics .typeahead").keydown(function(e) {
              if (e.keyCode == 13) {
                jQuery('#the-basics a').trigger('click');
                return false;
              }
            });
            jQuery('#the-basics a').on('click', function (e) {
              e.preventDefault();
              var val = jQuery(this).siblings('input').val();
              if(val !== ''){
                var a = 0;
                jQuery('.address-all .list .addr .row').each(function () {
                  var cc = jQuery(this).attr('data-area');
                  if(val == cc){
                    jQuery('.store-finder .address-box .list .addr-list').remove();
                    jQuery('.address-all .list .addr .row').each(function () {
                      var area = jQuery(this).attr('data-area');
                      var html = ''
                      if (val == area){
                        html += jQuery(this).html();
                        jQuery('.store-finder .address-box .list').append(html);

                        var Aactive = jQuery('.address-box .list .addr-list').attr('data-state');
                        jQuery('.store-finder .state li').each(function () {
                          var Cactive = jQuery(this).children('a').attr('data-state');
                          if(Aactive === Cactive){
                            jQuery(this).siblings('').removeClass('active');
                            jQuery(this).addClass('active');
                          }
                        })
                      }
                    });
                    initialize();
                    a++;
                  }
                });
                if(a==0){
                  jQuery('.store-finder .address-box .list').empty();
                  jQuery('.address-box .list').append('<div class="no-results">No results</div>');
                  initialize();
                }
              }else {
              }
            });
            jQuery('.store-finder .state li a').on('click', function (e) {
              e.preventDefault();

              jQuery('#the-basics input').val('');
              if(jQuery(this).parents('li').hasClass('active')){

              }else if(jQuery(this).attr('data-state') == 'all'){
                jQuery(this).parents('li').addClass('active').siblings().removeClass('active');
                var Ahtml = '';
                jQuery('.store-finder .address-all .list .addr .row').each(function () {
                  Ahtml += jQuery(this).html();
                });
                jQuery('.store-finder .address-box .list .addr-list').remove();
                jQuery('.store-finder .address-box .list').prepend(Ahtml);
                initialize();
              }else{



                jQuery(this).parents('li').addClass('active').siblings().removeClass('active');
                var state = jQuery(this).attr('data-state');
                var Shtml = ''
                var st = 0;
                jQuery('.store-finder .address-all .list .addr .row').each(function () {
                  states = jQuery(this).attr('data-state');
                  if(state == states){
                    Shtml += jQuery(this).html();
                    jQuery('.store-finder .address-box .list').empty();
                    jQuery('.store-finder .address-box .list').append(Shtml);
                    st++;
                  }
                });
                if(st==0){
                  jQuery('.store-finder .address-box .list').empty();
                  jQuery('.address-box .list').append('<div class="no-results">No results</div>');
                  jQuery('.addedmark').remove();
                }else{
                  initialize();
                }



              }

              //                     if(map.getZoom()>18){
              //                     	map.setZoom(18);
              //                     }

            });
            jQuery('body').on('click', '.address-box .list .addr-list',function() {
             
              jQuery('#the-basics input').val('');
              var index = jQuery(this).index();
              jQuery(this).addClass('open').siblings().removeClass('open');
              if(jQuery(this).hasClass('open')){
                jQuery('.addedmark').removeClass('on');
                jQuery('.addedmark').parent().find('.addedmark').eq(index).addClass('on');
                jQuery('.addedmark').parent().find('.addedmark').eq(index).trigger('click');
                var la = jQuery(this).attr('data-la');
                var lo = jQuery(this).attr('data-lo');
                map.panTo(new google.maps.LatLng(la, lo));
                if(map.getZoom()>18){
                  map.setZoom(18);
                }
              }else{
                jQuery('.addedmark').parent().find('.addedmark').eq(index).removeClass('on');
              }
            });
            initialize();
          </script>
        </div>
    </div>
</section>
