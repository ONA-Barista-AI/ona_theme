}

/* === ONA DEV: Header nav + icon colors ===
   Only `.has-white-label` pages (home, product, about, training — deep-bg banner)
   need the default-white treatment. On non-white-label pages let live's base rule
   `nav .menu-list>li>a { color:#661a34 }` (main.css L1499) show through, matching
   the live theme's state-driven colour system.
   Sticky state (.smaller-header) and open-dropdown state (.header-right.hover)
   flip back to brand purple — those rules live in live main.css and are preserved. */
header.has-white-label .wrap-header nav.main-nav .menu-list > li > a,
header.has-white-label .wrap-header nav.main-nav .menu-list > li > a .site-nav__label,
header.has-white-label .wrap-header nav.main-nav .site-nav--has-dropdown .site-nav__link--button {
    color: #ffffff;
    -webkit-transition: color 0.2s ease-in-out;
    transition: color 0.2s ease-in-out;
}

/* Icon-list defaults: white on dark-bg header, brand purple elsewhere. */
header.has-white-label .wrap-header .icon-list li .icon-search:before,
header.has-white-label .wrap-header .icon-list li .icon-shop:before,
header.has-white-label .wrap-header .icon-list li .icon-user:before {
    color: #ffffff;
    -webkit-transition: color 0.2s ease-in-out, opacity 0.2s ease-in-out;
    transition: color 0.2s ease-in-out, opacity 0.2s ease-in-out;
}
header .wrap-header .icon-list li .icon-search:hover:before,
header .wrap-header .icon-list li .icon-shop:hover:before,
header .wrap-header .icon-list li .icon-user:hover:before {
    opacity: 0.75;
}

/* Mobile drawer keeps dark-red for legibility on white background.
   Round 10 提前 drawer 断点到 991.98，本条同步抬断点保持一致。 */
@media (max-width: 991.98px) {
    header.has-white-label .wrap-header nav.main-nav .menu-list > li > a,
    header.has-white-label .wrap-header nav.main-nav .menu-list > li > a .site-nav__label,
    header.has-white-label .wrap-header nav.main-nav .site-nav--has-dropdown .site-nav__link--button {
        color: #661a34;
    }
}

/* === ONA DEV: Open-dropdown sibling dimming (click-driven) ===
   When a has-dropdown li is clicked open, its siblings fade to brand purple.
   Previously used :has(:hover) — replaced with :has(.is-open) since dropdown
   is now click-toggled.
   Round 10 提前 drawer 断点到 991.98 → sibling dim 只在 ≥992 桌面态下生效。 */
@media (min-width: 992px) {
    header.has-white-label .wrap-header nav.main-nav .menu-list:has(> li.site-nav--has-dropdown.is-open) > li:not(.is-open) > a.site-nav__link--main,
    header.has-white-label .wrap-header nav.main-nav .menu-list:has(> li.site-nav--has-dropdown.is-open) > li:not(.is-open) > a.site-nav__link--main .site-nav__label {
        color: #661a34;
    }
}

/* === ONA DEV: Centered dropdown — drop the white plate and the 1200px cap
   so content can stretch full-width against the transparent backdrop.
   Overrides ona-fixes.css base styles for this specific dropdown variant. === */
.site-nav--has-centered-dropdown .site-nav__dropdown .site-nav__childlist,
.site-nav__dropdown--centered .site-nav__childlist {
    background: transparent !important;
    max-width: none !important;
    margin: 0;
    padding: 0;
}

/* === ONA DEV: Cart bubble — position matches live theme's top-left placement.
   Default state: white background, brand-purple text.
   Sticky state (.smaller-header): brand-purple background, white text. === */
.header-actions__cart-icon {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

/* Override base.css .button-unstyled { overflow: hidden } so the bubble can
   extend outside the trigger's top-left corner. */
.header-actions__cart-icon .ona-cart-trigger,
button.button-unstyled.ona-cart-trigger {
    position: relative;
    padding: 0;
    line-height: 1;
    overflow: visible;
}

.header-actions__cart-icon .cart-bubble {
    position: absolute;
    width: 17px;
    height: 17px;
    min-width: 17px;
    top: -12px;
    left: -14px;
    right: auto;
    aspect-ratio: 1;
    border-radius: 50%;
    font-size: 12px;
    line-height: 1;
    pointer-events: none;
}

/* Default: white bubble, purple text */
.header-actions__cart-icon .cart-bubble__background {
    background-color: #ffffff;
    border: 1px solid #661a34;
    border-radius: 50%;
}

.header-actions__cart-icon .cart-bubble__text,
.header-actions__cart-icon .cart-bubble__text-count {
    color: #661a34;
    font-size: 12px;
    line-height: 1;
}

/* Sticky state: flip to purple bubble, white text */
header.smaller-header .header-actions__cart-icon .cart-bubble__background {
    background-color: #661a34;
    border-color: #661a34;
}

header.smaller-header .header-actions__cart-icon .cart-bubble__text,
header.smaller-header .header-actions__cart-icon .cart-bubble__text-count {
    color: #ffffff;
}

/* Hover state: when any site-nav dropdown is being hovered, .header-right gets
   the .hover class (added by menuHamburger() in script.js:40-41). Mirror the
   sticky-state colour flip on the cart bubble so the whole icon cluster shifts
   colour together. */
header .header-right.hover .header-actions__cart-icon .cart-bubble__background {
    background-color: #661a34;
    border-color: #661a34;
}
header .header-right.hover .header-actions__cart-icon .cart-bubble__text,
header .header-right.hover .header-actions__cart-icon .cart-bubble__text-count {
    color: #ffffff;
}

/* Hide bubble entirely when cart empty (no count text) */
.header-actions__cart-icon cart-icon:has(.cart-bubble__text-count:empty) .cart-bubble,
.header-actions__cart-icon .cart-bubble.visually-hidden {
    display: none;
}

/* === ONA DEV: Featured-collection "View all" button hover ===
   Global `a:not([disabled]):hover` has specificity 0,2,1 and was overriding the
   section rule's color, making the hover text invisible. Selector below ties on
   specificity and wins by source order. */
a.ona-fc__view-all-link,
.ona-fc__view-all a.ona-fc__view-all-link {
    display: inline-block;
    padding: 10px 24px;
    border: 1px solid #661a34;
    background: transparent;
    color: #661a34;
    font: 400 14px/1 'Karla', sans-serif;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
}

a.ona-fc__view-all-link:hover,
a.ona-fc__view-all-link:focus,
.ona-fc__view-all a.ona-fc__view-all-link:hover,
.ona-fc__view-all a.ona-fc__view-all-link:focus {
    background: #661a34;
    color: #fff;
    border-color: #661a34;
    text-decoration: none;
}

/* === ONA DEV Round 3 === */

/* Banner-top-slider: 100vh + slick-friendly layout.
   Legacy rules at line ~17513 had `.slick-track { display: table !important }`
   and `.slider-list { display: table-cell !important; float: none !important;
   padding: 166px 0 71px }`. The critical bug: `float: none !important` kills
   slick's own `.slick-slide { float: left }` — in fade mode slick computes
   per-slide `left: -(slideWidth * index)` offsets via `slick.js:1955-1976`
   and those only resolve correctly when slides are float-laid out in the
   track. Symptom: only slide 1 ever rendered; slides 2/3 were offset to
   invisible positions.
   Fix: restore float:left, swap table to block, clear the giant padding, and
   centre content via a 100%-height .text wrapper inside the untouched
   Bootstrap .container (so max-width constraint is preserved). */
.banner-top-slider,
.banner-top-slider.slick-slider {
    height: 100vh;
    min-height: 100vh;
}
.banner-top-slider .slick-list {
    height: 100vh !important;
}
.banner-top-slider .slick-track {
    display: block !important;
    height: 100vh !important;
}
.banner-top-slider .slider-list {
    display: block !important;
    float: left !important;
    padding: 0 !important;
    height: 100vh !important;
    min-height: 100vh;
}
/* Bootstrap `.container` inside the slide should fill the slide height so
   its existing `display:flex; align-items:center` centres text+image
   vertically against the 100vh background. */
.banner-top-slider .slider-list .container {
    height: 100%;
}
.banner-top-slider.slick-dotted.slick-slider { margin-bottom: 0; }
@media (max-width:1199.98px) { .banner-top-slider.slick-dotted.slick-slider { margin-bottom: 0; } }
@media (max-width:991.98px)  { .banner-top-slider.slick-dotted.slick-slider { margin-bottom: 0; } }
@media (max-width:767.98px)  { .banner-top-slider.slick-dotted.slick-slider { margin-bottom: 0; } }
@media (max-width:575.98px)  { .banner-top-slider.slick-dotted.slick-slider { margin-bottom: 0; } }

/* Sticky header: plain main-nav links (non-dropdown parents) should also be
   brand-purple, matching .site-nav__link--button rule at line 1085. */
header.smaller-header nav .menu-list > li > a.site-nav__link--main,
header.smaller-header nav .menu-list > li > a.site-nav__link--main .site-nav__label {
    color: #661a34;
}

/* (Round 3 child-link right padding superseded by Round 4 rules below.) */

/* Footer .tel-row lives outside the .footer-menu <ul>, so it never inherited
   the "footer .footer-top ul li a" styling. Re-apply the same font/size/colour
   + hover to keep both rows visually identical. */
footer .footer-top .tel-row {
    font-family: "Karla";
    font-size: 30px;
    line-height: 1;
    color: #ffffff;
    margin-bottom: 18px;
}
@media (max-width:991.98px) {
    footer .footer-top .tel-row { margin-bottom: 14px; }
}
@media (max-width:767.98px) {
    footer .footer-top .tel-row { margin-bottom: 10px; }
}
@media (max-width:575.98px) {
    footer .footer-top .tel-row {
        font-size: 35px;
        margin-bottom: 7px;
    }
}
footer .footer-top .tel-row a {
    color: #ffffff;
    text-decoration: none;
}
footer .footer-top .tel-row a:hover {
    color: #f3b1c5;
}

/* === ONA DEV Round 4 === */

/* Dropdown child-link: symmetric horizontal padding + white hover background.
   Must beat ona-fixes.css which has `padding: 6px 14px !important` plus
   `background: transparent !important`. Use equal !important at same-or-higher
   specificity (source-order lets this win since main.css loads first but
   ona-fixes.css loads last — we actually need to raise specificity). */
@media (min-width: 750px) {
    .site-nav__dropdown .site-nav__link.site-nav__child-link,
    .site-nav__dropdown a.site-nav__link.site-nav__child-link {
        padding-left: 24px !important;
        padding-right: 24px !important;
    }
    .site-nav__dropdown .site-nav__link.site-nav__child-link:hover,
    .site-nav__dropdown a.site-nav__link.site-nav__child-link:hover,
    .site-nav__childlist-item > ul > li > a.site-nav__child-link:hover,
    .site-nav__childlist-item > ul > li > a.site-nav__child-link:hover .site-nav__label {
        background: #ffffff !important;
    }

    /* Task 5: centered dropdown child-link font Karla. Target the exact chain. */
    .site-nav__dropdown.site-nav__dropdown--centered .site-nav__childlist-grid > .site-nav__childlist-item > .site-nav__child-link,
    .site-nav__dropdown.site-nav__dropdown--centered .site-nav__childlist-grid > .site-nav__childlist-item > .site-nav__child-link .site-nav__label {
        font-family: Karla, sans-serif !important;
    }

    /* Task 6: level-3 links under a .site-nav__child-link--parent also Karla. */
    .site-nav__childlist-item:has(> .site-nav__child-link--parent) > ul li .site-nav__child-link,
    .site-nav__childlist-item:has(> .site-nav__child-link--parent) > ul li .site-nav__child-link .site-nav__label {
        font-family: Karla, sans-serif !important;
    }
}

/* Featured-product media: cap image size + horizontal centering.
   Section stylesheet (ona-featured-product.liquid) sets `.ona-fp__media img
   { width: 100%; height: auto }` — and loads AFTER main.css, so to override
   we need higher specificity. Scoping with `.ona-fp__grid .ona-fp__media img`
   gives us 0,3,1 vs. the section's 0,1,1. */
.ona-fp__grid .ona-fp__media {
    display: flex;
    justify-content: center;
    align-items: flex-start;
}
.ona-fp__grid .ona-fp__media img {
    max-width: 324.5560318432333px;
    max-height: 530px;
    margin-inline: auto;
    object-fit: contain;
}

/* === ONA DEV Round 5 === */

/* 三级菜单 ul：去除上下 padding。
   覆盖 ona-fixes.css 第 33/71 行的 `padding: 8px 0`。用 :has() 限定
   在 .site-nav__child-link--parent 之后的 ul，避免误伤其他 childlist-item
   下的 ul。ona-fixes.css 晚于 main.css 加载，靠特异性 (0,3,1) 胜出。 */
.site-nav__childlist-item:has(> .site-nav__child-link--parent) > ul {
    padding-top: 0 !important;
    padding-bottom: 0 !important;
}

/* 上一轮在 dropdown 内 a.site-nav__link 上加 text-align:center 过度覆盖，
   误伤了本应左对齐的多行/长文本菜单项。已移除。默认 inherit/left 由 live
   原样式控制；如后续需单独居中某一类子链，应用更窄的选择器单独处理。 */

/* === ona-slideshow (实际主页用的 slideshow section) 样式还原 live ===
   教训：dev/sections/slideshow.liquid 是 Horizon 内置 section 但没人用在主页；
   实际主页渲染的是 sections/ona-slideshow.liquid（class: "index-section
   index-section--flush index-section--slideshow"）。该 section 用 slick 而非
   Horizon Web Component，DOM 已用 live 的 class 名（.slideshow-wrapper /
   .slideshow__arrow / .slick-dots），但之前：
   1) 缺 .slideshow__controls > .slideshow__arrows 包装 → 现已在 section liquid 加上；
   2) section {% stylesheet %} 里自己写了 .slideshow__arrow 绝对定位两侧 + 底部 dots
      → 现已删除，让下面 main.css 规则接管。
   作用域 [data-section-type="ona-slideshow"] 限定在本 section。 */

[data-section-type="ona-slideshow"] .slideshow-wrapper {
    position: relative;
}

/* live theme.css:5124-5136 .slideshow__controls 位置：移动贴右上、桌面贴左下 */
[data-section-type="ona-slideshow"] .slideshow__controls {
    display: flex;
    justify-content: center;
    position: absolute;
    top: 0;
    right: 0;
    margin-bottom: 5px;
    z-index: 8;
}
@media only screen and (min-width: 750px) {
    [data-section-type="ona-slideshow"] .slideshow__controls {
        top: auto;
        bottom: 0;
        left: 0;
        right: auto;
    }
}

/* live theme.css:5138-5153 .slideshow__arrows 胶囊：黑底半透明，prev + dots + next */
[data-section-type="ona-slideshow"] .slideshow__controls .slideshow__arrows {
    height: 44px;
    padding: 5px;
    background-clip: content-box;
    background-color: rgba(0, 0, 0, 0.4);
    color: rgba(255, 255, 255, 0.5);
    transition: color 0.2s cubic-bezier(0.44, 0.13, 0.48, 0.87),
                background-color 0.2s cubic-bezier(0.44, 0.13, 0.48, 0.87);
    display: none;
}
@media only screen and (min-width: 750px) {
    [data-section-type="ona-slideshow"] .slideshow__controls .slideshow__arrows {
        display: flex;
    }
    [data-section-type="ona-slideshow"] .slideshow__controls:hover .slideshow__arrows,
    [data-section-type="ona-slideshow"] .slideshow__controls:focus-within .slideshow__arrows {
        background-color: rgba(0, 0, 0, 0.75);
    }
}

/* live theme.css:5154-5181 .slideshow__arrow prev/next 按钮：44x44 */
[data-section-type="ona-slideshow"] .slideshow__arrows .slideshow__arrow {
    height: 44px;
    width: 44px;
    position: relative;
    top: -5px;
    padding: 0 0.9rem;
    line-height: 0;
    cursor: pointer;
    transition: color 0.2s cubic-bezier(0.44, 0.13, 0.48, 0.87);
    background: transparent;
    color: rgba(255, 255, 255, 0.5);
    border: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}
[data-section-type="ona-slideshow"] .slideshow__arrows .slideshow__arrow:hover,
[data-section-type="ona-slideshow"] .slideshow__arrows .slideshow__arrow:focus-visible {
    color: #ffffff;
}
[data-section-type="ona-slideshow"] .slideshow__arrows .slideshow__arrow svg {
    width: 0.7rem;
    height: 0.7rem;
    fill: currentColor;
}
[data-section-type="ona-slideshow"] .slideshow__arrows .slideshow__arrow-previous {
    float: left;
}
[data-section-type="ona-slideshow"] .slideshow__arrows .slideshow__arrow-next {
    float: right;
}
@media only screen and (min-width: 750px) {
    [data-section-type="ona-slideshow"] .slideshow__arrows .slideshow__arrow-previous { order: -1; }
    [data-section-type="ona-slideshow"] .slideshow__arrows .slideshow__arrow-next { order: 1; }
}

/* live theme.css:5182-5205 .slick-dots：9x9 白点 + active 纯白 */
[data-section-type="ona-slideshow"] .slideshow__arrows .slick-dots {
    line-height: 32px;
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
}
[data-section-type="ona-slideshow"] .slideshow__arrows .slick-dots li {
    width: 9px;
    height: 9px;
    margin-left: 9px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    list-style: none;
}
[data-section-type="ona-slideshow"] .slideshow__arrows .slick-dots li:first-child {
    margin-left: 0;
}
/* slick.js 默认给 dot 渲染成 <li><button></button></li>。既覆盖 button 也覆盖 a（容错） */
[data-section-type="ona-slideshow"] .slideshow__arrows .slick-dots li button,
[data-section-type="ona-slideshow"] .slideshow__arrows .slick-dots li a {
    width: 9px;
    height: 9px;
    padding: 0;
    margin: 0;
    border: none;
    background: rgba(0, 0, 0, 0.7);
    border-radius: 50%;
    cursor: pointer;
    font-size: 0;
    opacity: 1;
    transition: background-color 0.2s ease;
    display: block;
    text-indent: -9999px;
    overflow: hidden;
}
@media only screen and (min-width: 750px) {
    [data-section-type="ona-slideshow"] .slideshow__arrows .slick-dots li button,
    [data-section-type="ona-slideshow"] .slideshow__arrows .slick-dots li a {
        background: rgba(255, 255, 255, 0.5);
    }
}
[data-section-type="ona-slideshow"] .slideshow__arrows .slick-dots li.slick-active button,
[data-section-type="ona-slideshow"] .slideshow__arrows .slick-dots li.slick-active a {
    background: #ffffff;
}

/* slick.js 默认在 button 上加 ::before 画默认 dot。全关掉。 */
[data-section-type="ona-slideshow"] .slideshow__arrows .slick-dots li button::before,
[data-section-type="ona-slideshow"] .slideshow__arrows .slick-dots li a::before {
    content: none;
    display: none;
}

/* === Round 5 (续): hamburger button reset + 垂直居中 + mobile drawer 提前到 991.98px === */

/* hamburger 作为 <button> 的默认样式 reset（background/border/padding/appearance）
   + 垂直居中：把硬编码 top:21px 改为 top:50% + translateY(-50%)，锚定 .header-right。 */

.hamburger {
    background: transparent;
    border: none;
    padding: 0;
    margin: 0;
    appearance: none;
    -webkit-appearance: none;
    outline: none;
    font: inherit;
    color: inherit;
    top: 50%;
    right: 0;
    transform: translateY(-50%);
}
.hamburger:focus-visible {
    outline: 2px solid #661a34;
    outline-offset: 2px;
}
/* hamburger.active 状态下三根 span 的 rotate/translate 不影响外层 translateY，
   但 :hover/:focus 不叠加 hamburger 外层 transform，故保留。 */

/* 提前 mobile drawer 行为到 991.98px：767-991 区间 header 主 nav 内容过多会换行，
   把 hamburger + drawer 形态从 767 提前到 991，与 live @media 767.98 的规则内容
   完全一致，仅断点扩展。 */
@media (max-width: 991.98px) {
    .hamburger {
        display: block;
    }

    nav {
        margin-top: 0;
        position: fixed;
        top: -100%;
        left: 0;
        z-index: 1001;
        width: 100%;
        height: 100%;
        background: #e5e6e2;
        transition: top 0.6s cubic-bezier(0.77, 0, 0.175, 1);     padding: 181px 30px 45px;
    }
    nav.main-nav .nav-menu,
    nav .nav-menu {
        position: absolute;
        top: 132px;
        left: 0;
        bottom: 0;
        right: 0;
   
        overflow-y: auto;
        align-items: flex-start;
    }

    nav.main-nav .menu-list {
        flex-direction: column;
        align-items: flex-start;
        margin-bottom: 31px;
    }

    nav.main-nav .menu-list > li {
        margin: 0 0 20px;
        font-size: 35px;
        line-height: 42px;
        width: 100%;
        text-align: left;
    }

    nav.main-nav .menu-list > li .site-nav__label {
        font-size: 35px;
    }

    nav.main-nav .menu-list > li.site-nav--active .site-nav__dropdown {
        display: block !important;
    }

    nav.main-nav .menu-list > li > a {
        display: inline-block;
    }

    nav.main-nav .site-nav__dropdown {
        position: static;
        top: auto;
        left: auto;
        width: 100%;
        padding: 15px 10px;
        opacity: 1;
        visibility: visible;
        display: none;
        height: auto;
        background: transparent;
        transition: all 0s ease-in-out;
    }

    nav.main-nav .site-nav__dropdown ul {
        max-width: 100%;
        margin-left: 0;
    }

    nav.main-nav .site-nav__dropdown ul li a {
        padding: 16px 0 22px !important;
    }

    nav.main-nav .site-nav__dropdown ul li .icon-arrow-smaller {
        top: 23px;
    }

    nav.main-nav .another-menu-list {
        display: flex;
        flex-wrap: wrap;
        flex-direction: column;
        align-items: flex-start;
        margin-bottom: 66px;
    }

    nav.main-nav .social-list {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
    }

    header .header-right {
        padding-right: 58px;
    }

    header .icon-list {
        margin-left: 0;
    }

    header .icon-list li {
        margin: 0 0 0 30px;
    }

    header .icon-list li:first-child {
        margin: 0;
    }

    header .header {
        padding: 29px 0;
        border-bottom: none;
        align-items: flex-start;
    }

    header .logo img {
        width: 46px;
    }

    /* drawer 打开时背景是浅色 #e5e6e2，各 state class 下主菜单链接需变深红 */
    header.has-white-label nav .menu-list > li > a,
    header.white-logo nav .menu-list > li > a,
    header.darkred-color nav .menu-list > li > a {
        color: #661a34;
    }
    header.has-white-label nav .menu-list > li > a:before,
    header.white-logo nav .menu-list > li > a:before,
    header.darkred-color nav .menu-list > li > a:before {
        background: #661a34;
    }
    header.has-white-label nav .site-nav--has-dropdown .site-nav__link--button,
    header.white-logo nav .site-nav--has-dropdown .site-nav__link--button {
        color: #661a34;
    }

    /* header.darkred-color（login/register）移动端 body 背景浅色 */
    header.darkred-color {
        background: #fbf8f3;
    }

    /* sticky 状态下 header padding 也按 mobile 收紧（live:1069） */
    header.smaller-header .header {
        padding: 29px 0;
    }
}

/* === ONA DEV Round 6 === */

/* ---- (1) icon-list li 间距一致 ----
   三个 li 的子元素是不同 Web Component (shopify-account / search-button /
   cart-drawer-component)，默认 display / line-height / 子结构各异，导致
   li 外形尺寸不一、左 margin 23px 下视觉间距不均。把三种 wrapper 统一为
   inline-flex + align-items:center + line-height:1，使每个 li 只有图标
   本身宽度，间距完全由 li 的 margin 决定。 */
header .icon-list li > shopify-account,
header .icon-list li > search-button,
header .icon-list li > cart-drawer-component {
    display: inline-flex;
    align-items: center;
    line-height: 1;
    padding: 0;
    margin: 0;
}
/* cart-drawer-component 内有 <template>/<dialog>/<script>/<span.visually-hidden>
   这些 0-宽度或隐藏元素，确保只有 <cart-icon> 参与布局。 */
header .icon-list li > cart-drawer-component > template,
header .icon-list li > cart-drawer-component > script {
    display: none;
}

/* ---- (2) ona-slideshow: 控件与 mobile 文本结构 ---- */

/* 2.1 slideshow__controls 桌面水平居中
   原 live 设计是 bottom-left，用户要求改为底部居中。去掉 right:0/left:0 的
   偏一边定位，改用 left:0; right:0 全宽 + justify-content:center 让内部
   .slideshow__arrows 居中。 */
[data-section-type="ona-slideshow"] .slideshow__controls {
    left: 0;
    right: 0;
    justify-content: center;
}
@media only screen and (min-width: 750px) {
    [data-section-type="ona-slideshow"] .slideshow__controls {
        left: 0;
        right: 0;
    }
}

/* 2.2 .slideshow__arrows 内部 prev / dots / next 水平居中，取消 float */
[data-section-type="ona-slideshow"] .slideshow__arrows {
    justify-content: center;
}
[data-section-type="ona-slideshow"] .slideshow__arrows .slideshow__arrow-previous,
[data-section-type="ona-slideshow"] .slideshow__arrows .slideshow__arrow-next {
    float: none;
}

/* 2.3 手机端 slideshow__text-wrap--mobile + __text-content--mobile + __arrows--mobile
   对齐 live/assets/theme.css:5001-5218。 */
[data-section-type="ona-slideshow"] .slideshow__text-wrap--mobile {
    display: none;
}
@media only screen and (max-width: 749px) {
    [data-section-type="ona-slideshow"] .slideshow__text-wrap--mobile {
        display: block;
        position: relative;
        top: -1.1rem;
        background-color: #ffffff;
        width: 85%;
        margin: 0 0 -1.1rem 7.5%;
        z-index: 8;
    }
}

[data-section-type="ona-slideshow"] .slideshow__arrows--mobile {
    display: block;
    width: 100%;
    height: 44px;
    padding: 0;
    background-color: transparent;
}
@media only screen and (min-width: 750px) {
    [data-section-type="ona-slideshow"] .slideshow__arrows--mobile {
        display: none;
    }
}
[data-section-type="ona-slideshow"] .slideshow__arrows--mobile .slick-dots {
    display: flex;
    justify-content: center;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 14px 0 0;
    line-height: 1;
}
[data-section-type="ona-slideshow"] .slideshow__arrows--mobile .slick-dots li {
    width: 9px;
    height: 9px;
    margin-left: 9px;
    padding: 0;
    list-style: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}
[data-section-type="ona-slideshow"] .slideshow__arrows--mobile .slick-dots li:first-child {
    margin-left: 0;
}
[data-section-type="ona-slideshow"] .slideshow__arrows--mobile .slick-dots li button {
    width: 9px;
    height: 9px;
    padding: 0;
    margin: 0;
    border: none;
    background: rgba(102, 26, 52, 0.4);
    border-radius: 50%;
    cursor: pointer;
    font-size: 0;
    opacity: 1;
    transition: background-color 0.2s ease;
    display: block;
    text-indent: -9999px;
    overflow: hidden;
}
[data-section-type="ona-slideshow"] .slideshow__arrows--mobile .slick-dots li.slick-active button {
    background: #661a34;
}
[data-section-type="ona-slideshow"] .slideshow__arrows--mobile .slick-dots li button::before {
    content: none;
    display: none;
}

[data-section-type="ona-slideshow"] .slideshow__text-content--mobile {
    display: none;
    padding: 1.7rem 0 2rem;
    color: #661a34;
    text-align: center;
}
[data-section-type="ona-slideshow"] .slideshow__text-content--mobile.slideshow__text-content--mobile-active {
    display: block;
}
[data-section-type="ona-slideshow"] .slideshow__title--mobile {
    margin-bottom: 0.5rem;
    color: inherit;
}
[data-section-type="ona-slideshow"] .slideshow__subtitle--mobile {
    color: inherit;
}
[data-section-type="ona-slideshow"] .slideshow__btn--mobile {
    display: inline-block;
    margin: 1.3rem auto 0.3rem;
}

/* 桌面端隐藏 __title--mobile / __subtitle--mobile / __btn--mobile */
@media only screen and (min-width: 750px) {
    [data-section-type="ona-slideshow"] .slideshow__title--mobile,
    [data-section-type="ona-slideshow"] .slideshow__subtitle--mobile,
    [data-section-type="ona-slideshow"] .slideshow__btn--mobile {
        display: none;
    }
}

/* 2.4 sticky 防御：jQuery 的 slick-dots 兜底隐藏只作用于真正的 slick-initialized
   容器（script.js 已修），但万一有异步加载 slider，保险起见让 ona-slideshow
   的 slick-dots 始终占位。 */
[data-section-type="ona-slideshow"] .slick-dots {
    display: flex !important;
}

/* ---- (3) main-nav 991 drawer 与 live 767 对齐补齐 ----
   之前 dev 把 @media 767→991，但 .site-nav__dropdown 的 height 被设为 auto，
   live 767 用的是 100%（当 drawer 作为 fixed 全屏覆盖层时，保证其子菜单区
   内不会意外撑开祖先高度）。虽然 dev 的 position:static 下二者差别较小，
   但为了样式一致（避免某些浏览器 block 元素后续滚动差异），改回 100%。 */
@media (max-width: 991.98px) {
    nav.main-nav .site-nav__dropdown {
        height: 100%;
    }
    /* 对齐 live:1654-1658 —— drawer 打开时子菜单 ul 宽度满溢 */
    nav.main-nav .site-nav__dropdown ul {
        max-width: 100%;
        margin-left: 0;
    }
    /* live 顶层规则 nav .menu-list>li .site-nav__label 在 767 下字号放大，
       dev 的 nav.main-nav 版已有，但漏了未加 main-nav 前缀的 .site-nav__label
       hover 保持不变；这里不重复加。 */
}

/* === ONA DEV Round 7 === */

/* Task 3: dropdown 打开时 icon-list 图标变紫。
   click 打开后 .header-right 获得 .hover class（由 script.js 添加）。
   live 的 main.css L1206/L1214 有 `.header-right.hover .icon-list li a/button:before
   { color:#661a34 }`，但在 has-white-label 页面会被 Round 1 的 0,4,4 白色规则
   覆盖（相同特异性、后加载胜出）。这里加回更高特异性 + 后加载的版本。 */
header .header-right.hover .icon-list li .icon-search:before,
header .header-right.hover .icon-list li .icon-shop:before,
header .header-right.hover .icon-list li .icon-user:before {
    color: #661a34;
}
header.has-white-label .header-right.hover .icon-list li .icon-search:before,
header.has-white-label .header-right.hover .icon-list li .icon-shop:before,
header.has-white-label .header-right.hover .icon-list li .icon-user:before,
header.white-logo .header-right.hover .icon-list li .icon-search:before,
header.white-logo .header-right.hover .icon-list li .icon-shop:before,
header.white-logo .header-right.hover .icon-list li .icon-user:before {
    color: #661a34;
}

/* 同理：dropdown 打开时（.header-right.hover） main-nav link 也要恢复紫色。
   live L1194 已有规则但同样被 Round 1 覆盖，这里补回。 */
header.has-white-label .header-right.hover nav.main-nav .menu-list > li > a,
header.has-white-label .header-right.hover nav.main-nav .menu-list > li > a .site-nav__label,
header.white-logo .header-right.hover nav.main-nav .menu-list > li > a,
header.white-logo .header-right.hover nav.main-nav .menu-list > li > a .site-nav__label {
    color: #661a34;
}

/* Task 2 配套：click 打开的 has-dropdown 自己的 link 也是紫（之前由 :hover 处理，
   现在换成 .is-open）。 */
nav.main-nav .menu-list > li.site-nav--has-dropdown.is-open > a.site-nav__link--main,
nav.main-nav .menu-list > li.site-nav--has-dropdown.is-open > a.site-nav__link--main .site-nav__label {
    color: #661a34;
}
nav.main-nav .menu-list > li.site-nav--has-dropdown.is-open > a.site-nav__link--main:before {
    left: 0;
    right: auto;
    width: 100%;
    background: #661a34;
}

/* 移动端 drawer 里 dropdown base 是 display:none（Round 5 L23695），
   光 opacity/visibility 不足以展开，需要显式 display:block。 */
@media (max-width: 991.98px) {
    nav.main-nav .menu-list > li.is-open .site-nav__dropdown {
        display: block;
    }
}

/* === ONA DEV Round 9 === */

/* 非 dropdown 的 main-nav li: hover 时 color 不强制变紫，:before 下划线显示**白色**。
   live 原逻辑是紫字 + 紫色下划线，本轮需求是保留下划线展开动画但颜色改白。
   - L1489 紫色 color 由 has-white-label/white-logo scope 下 hover 保持白色覆盖。
   - L1493 紫色 :before background 全局改 white。
   - L1528 `... >li>a:hover:before { width:100% }` 保留 — 动画自然展开白色下划线。 */

/* 1. 非 dropdown li 的 hover 下划线改为白色（覆盖 live L1493 紫色） */
nav.main-nav .menu-list > li:not(.site-nav--has-dropdown) > a.site-nav__link:hover:before,
nav.main-nav .menu-list > li:not(.site-nav--has-dropdown):hover > a.site-nav__link:before {
    background: #ffffff;
}

/* 2. has-white-label / white-logo 下：hover color 保持白色（压制 live L1489 的紫色 hover） */
header.has-white-label .wrap-header nav.main-nav .menu-list > li:not(.site-nav--has-dropdown):hover > a.site-nav__link,
header.has-white-label .wrap-header nav.main-nav .menu-list > li:not(.site-nav--has-dropdown):hover > a.site-nav__link .site-nav__label,
header.white-logo .wrap-header nav.main-nav .menu-list > li:not(.site-nav--has-dropdown):hover > a.site-nav__link,
header.white-logo .wrap-header nav.main-nav .menu-list > li:not(.site-nav--has-dropdown):hover > a.site-nav__link .site-nav__label {
    color: #ffffff;
}

/* === ONA DEV Round 10 === */

/* 任务 1（对齐 dev 991.98 与 live 767.98 nav 样式）已由 Round 5 (续) 完成，见
   L23642 起的 `@media (max-width: 991.98px)` block —— 选择器用 `nav.main-nav
   .menu-list / .site-nav__dropdown / .another-menu-list` 等，内容与 live 767.98
   等价。本轮真正的差异是 Round 1 的 drawer 紫字规则 media query 还停在
   `@media (max-width: 767.98px)` (原 L23178)，导致 768–991.98 区间 drawer 展开
   后 link 仍被 Round 1 默认白字 (0,4,4) 压过 Round 5 紫字 (0,2,4) —— 浅灰背景
   上白字看不见。已把 Round 1 的 media 断点抬到 991.98；同时把 dropdown sibling
   dim 的 `@media (min-width: 768px)` 抬到 992 避免在 drawer 内误触发。 */

/* Sticky (smaller-header) 下 icon-list 图标全部紫色 —— 不限 has-white-label /
   white-logo / darkred-color。覆盖 Round 1 的白色规则 (0,4,3)。
   特异性 (0,4,3)，source-order 后胜 Round 1。 */
header.smaller-header .wrap-header .icon-list li .icon-search:before,
header.smaller-header .wrap-header .icon-list li .icon-shop:before,
header.smaller-header .wrap-header .icon-list li .icon-user:before {
    color: #661a34;
}

/* Mobile drawer 打开 (nav.main-nav.is-show) 下 icon 紫色 —— 仅在 ≤991.98
   移动端断点生效，因为 nav.is-show 只有在 drawer 形态下才会出现；桌面态
   下 hamburger 不显示，也不会触发该 class。
   drawer 展开后 nav 背景是 #e5e6e2 浅灰，白 icon 看不清，需变紫。 */
@media (max-width: 991.98px) {
    header:has(nav.main-nav.is-show) .wrap-header .icon-list li .icon-search:before,
    header:has(nav.main-nav.is-show) .wrap-header .icon-list li .icon-shop:before,
    header:has(nav.main-nav.is-show) .wrap-header .icon-list li .icon-user:before {
        color: #661a34;
    }
}

/* ≤991.98 断点下 .header-right 设 position: relative —— 为 hamburger (absolute
   top:50%; right:0) 提供定位锚点。Round 5 (续) 里 hamburger 用 translateY(-50%)
   垂直居中，依赖最近 positioned 祖先；之前靠 .header 或更外层兜底，显式声明
   让锚点固定在 header-right 上更稳，不会被别的 section 重排时漂移。 */
@media (max-width: 991.98px) {
    header .header-right {
        position: relative;
    }
}
