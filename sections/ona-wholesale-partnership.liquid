<section class="add-image-and-text wowo fadeInUp" data-wow-duration="1s" data-wow-delay="300ms">
    <div class="container">
        <div class="content">
            <div class="img show-icon wowo fadeInLeft" data-wow-duration="1s" data-wow-delay="300ms">
                {% if section.settings.media_type == 'embed' or section.settings.media_type == 'upload' %}
              <div class="scale-video">
                {% assign unique_id = 'now' | date: '%s' %}
                {%assign player_id = section.settings.id | append: 'uplaod_video_' | append:unique_id %}
                {% assign video_id = '' %}
                {% assign video_url = '' %}

                {% assign autoplay = section.settings.autoplay %}
                {% if section.settings.media_type == 'upload' %}
                      {% assign video_id = section.settings.video.sources[0].url %}
                      {% assign video_url = video_id %}
                      <video id="{{ player_id }}" class="video-js" controls muted defaultMuted playsinline preload="auto" data-src="{{video_id}}"></video>
                {% else %}
                    {% assign video_url = section.settings.video_url %}
                    {% if video_url contains 'v=' %}{% assign video_id = video_url | split: 'v=' | last | split: '&' | first %}{% else %}{% assign video_id = video_url | split: '/' | last | split: '?' | first %}{% endif %}
                    {% if video_url contains 'vimeo' %}
                        <iframe id="{{ player_id }}" src="https://player.vimeo.com/video/{{ video_id }}?h=29e872ad25" data-auto="{{ autoplay }}" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen playsinline></iframe>
                    {% else if video_url != '' %}
                        <div id="{{ player_id }}" data-auto="{{ autoplay }}"></div>
                    {% endif  %}
                 {% endif  %}
                </div>
                <a class="scale-cover-video play-video" data-auto="{{ autoplay }}" data-url="{{ video_url }}" data-video="{{ video_id }}" data-type="{{ section.settings.media_type }}" data-id="{{ player_id }}">
                    {% if section.settings.play_icon != blank %}<img src="{{ section.settings.play_icon | img_url: '100x' }}" alt="title-play-video" />{% endif %}
                </a>
              {%- comment -%} R36: video cover image. Above fold on /pages/wholesale, eager loading. {%- endcomment -%}
              {%- assign wp_cover_h = 800 | divided_by: section.settings.image.aspect_ratio | round -%}
              <img  src="{{ section.settings.image | img_url: '800x' }}" alt="{{ section.settings.image.alt | escape }}" width="800" height="{{ wp_cover_h }}" loading="eager" decoding="async" class="wowo fadeInup scale-cover-image" data-wow-duration="0.75s" data-wow-delay="300ms">
              {% else %}
                {%- assign wp_img_h = 1188 | divided_by: section.settings.image.aspect_ratio | round -%}
                <img src="{{ section.settings.image | img_url: '1188x' }}" alt="{{ section.settings.image.alt | escape }}" width="1188" height="{{ wp_img_h }}" loading="eager" decoding="async">
                <h2 class="title-large title-white wowo fadeIn" data-wow-duration="1s" data-wow-delay="500ms"><span>{{ section.settings.main_title }}</span></h2>
              {% endif %}
            </div>
            <div class="text wowo fadeInDown">
                <span class="subtitle">{{ section.settings.title }}</span>
                <h3>{{ section.settings.subtitle2 }}</h3>
                 {{ section.settings.content }} 
                <p>
                  <a href="https://forms.monday.com/forms/6b1a3a5478c16210a1dae4ae5b3f86dc?r=use1" class="more-btn" target="_blank" rel="noreferrer noopener">Get In Touch</a>
                </p>
            </div>
        </div>
    </div>
</section>

{% schema %}
{
  "name": {
    "en": "Wholesale partnership"
  },
  "settings": [    
    {
      "type": "text",
      "id": "main_title",
      "label": {
		"en": "Main Title"
      }
    },
    {
      "type": "text",
      "id": "title",
      "label": {
		"en": "Title"
      }
    },
    {
      "type": "text",
      "id": "subtitle2",
      "label": {
		"en": "Subtitle"
      }
    },
    {
      "type": "richtext",
      "id": "content",
      "label": {
		"en": "Content"
      }
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media Type",
      "info": "Select media to show",
      "options": [
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "embed",
          "label": "YouTube/Vimeo URL"
        },
        {
          "value": "upload",
          "label": "Upload Video"
        }    
      ]
    },  
    {
      "type": "image_picker",
      "id": "image",
      "info": "This image will be used as cover image if video is selected",
      "label": {
		"en": "Image"
      }
    },
    {
      "type": "video",
      "id": "video",  
      "label": "Select Video"
    },
    {
        "type": "video_url",
        "id": "video_url",
        "label": "YouTube/Vimeo",
        "accept": [
          "youtube",
          "vimeo"
        ]
      },
    {
      "type": "image_picker",
      "id": "play_icon",      
      "label": {
		"en": "Play Icon"
      }
    },
    {
        "type": "checkbox",
        "id": "autoplay",
        "label": "Enable Auto Play",
        "default":true
      }
  ]
}
{% endschema %}

