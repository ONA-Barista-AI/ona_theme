{% schema %}
{
  "name": "ONA store finder",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find a store" },
    { "type": "text", "id": "google_api_key", "label": "Google Maps API key", "info": "Restricted to ona-coffee domains in Google Cloud Console" },
    { "type": "text", "id": "fallback_lat", "label": "Fallback latitude", "default": "-35.2809" },
    { "type": "text", "id": "fallback_lng", "label": "Fallback longitude", "default": "149.1300" }
  ],
  "presets": [
    { "name": "ONA store finder" }
  ],
  "enabled_on": { "templates": ["page"] }
}
{% endschema %}
