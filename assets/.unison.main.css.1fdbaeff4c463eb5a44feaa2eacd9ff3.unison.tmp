}

.add-faqs-section .add-faqs .block .faqs-title {
	cursor: pointer;
	-webkit-transition: all 0.2s;
	transition: all 0.2s;
	padding: 10px 40px 10px 0;
	position: relative;
	padding: 20px 40px 20px 0
}

.add-faqs-section .add-faqs .block .faqs-title:after,
.add-faqs-section .add-faqs .block .faqs-title:before {
	content: "";
	width: 17px;
	height: 1px;
	background: #661a34;
	position: absolute;
	top: 32px;
	right: 5px;
	-webkit-transition: all 0.2s;
	transition: all 0.2s
}

.add-faqs-section .add-faqs .block .faqs-title:before {
	-webkit-transform: rotate(90deg);
	transform: rotate(90deg)
}

.add-faqs-section .add-faqs .block .faqs-title.is-active:before {
	-webkit-transform: rotate(45deg);
	transform: rotate(45deg)
}

.add-faqs-section .add-faqs .block .faqs-title.is-active:after {
	-webkit-transform: rotate(-45deg);
	transform: rotate(-45deg)
}

.add-faqs-section .add-faqs .block .faqs-title:hover {
	opacity: 0.7
}

.add-faqs-section .add-faqs .block .faqs-title p {
