<section class="two-columns-text" id="flagships_content">
  <div class="container">
    <div class="content">
      <div class="left-box wowo fadeInUp">
        <h2>{{ section.settings.heading }}</h2>
      </div>
      <div class="right-box wowo fadeInUp">
        {% if section.settings.body != blank %}
          {{ section.settings.body }}
        {% elsif page.content.size > 0 %}
          {{ page.content }}
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Flagship intro",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Flagship stores"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "info": "Leave blank to fall back to page content"
    }
  ],
  "presets": [
    {
      "name": "Flagship intro",
      "category": "Text"
    }
  ]
}
{% endschema %}
