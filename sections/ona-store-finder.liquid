{%- liquid
  assign google_key = section.settings.google_api_key | default: 'AIzaSyAuyn7RdlRUKeo53OFGodNcSX36C2pmJ7k'
  assign fallback_lat = section.settings.fallback_lat | default: '-35.2809'
  assign fallback_lng = section.settings.fallback_lng | default: '149.1300'
  assign heading = section.settings.heading | default: 'Find a store'
  assign all_tags = shop.metaobjects.store_tag.values
-%}

<section class="ona-sf" data-section-id="{{ section.id }}">
  <div class="ona-sf__inner">
    <h2 class="ona-sf__heading">{{ heading }}</h2>

    <div class="ona-sf__searchbar">
      <div class="ona-sf__search-wrap">
        <input type="text"
               class="ona-sf__search"
               id="ona-sf-search-{{ section.id }}"
               placeholder="Search a store name, suburb or address — press Enter or click the button"
               aria-label="Search location">
        <button type="button" class="ona-sf__search-clear" data-ona-sf-search-clear aria-label="Clear search" hidden>&times;</button>
      </div>
      <button type="button" class="ona-sf__near-me" data-ona-sf-near-me>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/><line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/></svg>
        Use my location
      </button>
    </div>

    {%- if all_tags.size > 0 -%}
      <div class="ona-sf__filters" role="group" aria-label="Filter by tag">
        <button type="button" class="ona-sf__chip is-active" data-ona-sf-tag="__all">All</button>
        {%- for tag in all_tags -%}
          <button type="button" class="ona-sf__chip" data-ona-sf-tag="{{ tag.slug.value }}">{{ tag.label.value }}</button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="ona-sf__rs" data-ona-sf-distance-filter>
      <div class="ona-sf__rs-summary">
        Within <strong data-ona-sf-distance-value>500</strong> km of <strong data-ona-sf-distance-anchor>—</strong>
      </div>
      <div class="ona-sf__rs-track-wrap">
        <span class="ona-sf__rs-bubble" data-ona-sf-rs-bubble>500</span>
        <input type="range" min="1" max="500" value="500" step="1" class="ona-sf__rs-input" data-ona-sf-distance-slider aria-label="Maximum distance in kilometres">
        <div class="ona-sf__rs-ticks" aria-hidden="true">
          <span>1 km</span><span>100 km</span><span>200 km</span><span>300 km</span><span>400 km</span><span>500 km</span>
        </div>
      </div>
      <p class="ona-sf__rs-hint" data-ona-sf-distance-hint>Use "Use my location" or search an address to enable distance filtering.</p>
    </div>

    <div class="ona-sf__toolbar">
      <span class="ona-sf__count" data-ona-sf-count>stores</span>
      <div class="ona-sf__view-toggle" role="tablist">
        <button type="button" class="ona-sf__view-btn is-active" data-ona-sf-view="list" role="tab">List</button>
        <button type="button" class="ona-sf__view-btn" data-ona-sf-view="map" role="tab">Map</button>
      </div>
    </div>

    <div class="ona-sf__no-results" data-ona-sf-empty hidden>
      <p data-ona-sf-empty-filter>No stores match your filters. <button type="button" class="ona-sf__link" data-ona-sf-reset>Clear filters</button></p>
      <p data-ona-sf-empty-search hidden>No search results found.</p>
    </div>

    <div class="ona-sf__layout" data-ona-sf-layout>
      <div class="ona-sf__list" data-ona-sf-list>
        {%- paginate shop.metaobjects.store_location.values by 500 -%}
        {%- for loc in shop.metaobjects.store_location.values -%}
          {%- if loc.latitude.value == blank or loc.longitude.value == blank -%}{%- continue -%}{%- endif -%}
          {%- assign loc_tag_slugs = '' -%}
          {%- for t in loc.tags.value -%}
            {%- assign loc_tag_slugs = loc_tag_slugs | append: t.slug.value | append: ',' -%}
          {%- endfor -%}
          <article class="ona-sf__card"
                   data-ona-sf-card
                   data-id="store-{{ forloop.index }}"
                   data-lat="{{ loc.latitude.value }}"
                   data-lng="{{ loc.longitude.value }}"
                   data-tags="{{ loc_tag_slugs }}"
                   data-search-text="{{ loc.title.value | append: ' ' | append: loc.storeaddress.value | append: ' ' | append: loc.suburb.value | append: ' ' | append: loc.state.value | downcase | escape }}">
            {%- if loc.image.value != blank -%}
              <div class="ona-sf__card-image">
                <img src="{{ loc.image.value | image_url: width: 600 }}" alt="{{ loc.title.value | escape }}" loading="lazy">
              </div>
            {%- endif -%}
            <div class="ona-sf__card-body">
              <h3 class="ona-sf__card-title">{{ loc.title.value }}</h3>
              <p class="ona-sf__card-address">{{ loc.storeaddress.value }}</p>
              {%- if loc.time.value != blank -%}
                <div class="ona-sf__card-hours">{{ loc.time | metafield_tag }}</div>
              {%- endif -%}
              {%- if loc.tags.value.size > 0 -%}
                <div class="ona-sf__card-tags">
                  {%- for t in loc.tags.value -%}
                    <span class="ona-sf__card-tag">{{ t.label.value }}</span>
                  {%- endfor -%}
                </div>
              {%- endif -%}
              {%- if loc.overview.value != blank -%}
                <div class="ona-sf__card-overview rte">{{ loc.overview | metafield_tag }}</div>
              {%- endif -%}
              <div class="ona-sf__card-actions">
                {%- if loc.latitude.value != blank and loc.longitude.value != blank -%}
                  <a class="ona-sf__btn ona-sf__btn--primary"
                     href="https://www.google.com/maps/dir/?api=1&destination={{ loc.latitude.value }},{{ loc.longitude.value }}"
                     target="_blank"
                     rel="noopener">Get directions</a>
                {%- endif -%}
                {%- if loc.storeaddressurl.value != blank -%}
                  <a class="ona-sf__btn" href="{{ loc.storeaddressurl.value }}" target="_blank" rel="noopener">Website</a>
                {%- endif -%}
                <span class="ona-sf__card-distance" data-ona-sf-distance></span>
              </div>
            </div>
          </article>
        {%- endfor -%}
        {%- endpaginate -%}
      </div>

      <div class="ona-sf__pagination" data-ona-sf-pagination hidden role="navigation" aria-label="List pagination">
        <button type="button" class="ona-sf__page-btn ona-sf__page-prev" data-ona-sf-page-prev>Previous</button>
        <ul class="ona-sf__page-list" data-ona-sf-page-list></ul>
        <button type="button" class="ona-sf__page-btn ona-sf__page-next" data-ona-sf-page-next>Next</button>
      </div>

      <div class="ona-sf__map-wrap" data-ona-sf-map-wrap>
        <div class="ona-sf__map" id="ona-sf-map-{{ section.id }}"></div>
      </div>
    </div>
  </div>
</section>

<script>
  window.__onaSf = window.__onaSf || {};
  window.__onaSf['{{ section.id }}'] = {
    fallbackLat: parseFloat({{ fallback_lat | json }}),
    fallbackLng: parseFloat({{ fallback_lng | json }}),
    apiKey: {{ google_key | json }},
    markerIcon: {{ 'map-active.svg' | asset_url | json }}
  };
</script>
<script defer src="{{ 'ona-store-finder.js' | asset_url }}"></script>

{% stylesheet %}
  .ona-sf {
    padding: 0 0 120px;
    background: #faf7f2;
  }
  .ona-sf__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 70px;
  }
  @media (max-width: 1199.98px) {
    .ona-sf__inner { padding: 0 50px; }
  }
  @media (max-width: 991.98px) {
    .ona-sf__inner { padding: 0 30px; }
  }
  .ona-sf__heading {
    font-family: 'Silk Serif Black', serif;
    font-size: 50px;
    line-height: 1.32;
    letter-spacing: -0.4px;
    color: #2b2c30;
    margin: 0 0 23px;
    font-weight: normal;
  }
  @media (max-width: 1199.98px) {
    .ona-sf__heading { font-size: 45px; }
  }
  @media (max-width: 991.98px) {
    .ona-sf__heading { font-size: 40px; }
  }
  @media (max-width: 767.98px) {
    .ona-sf__heading {
      font-size: 35px;
      line-height: 1.2;
      margin-bottom: 33px;
    }
  }
  .ona-sf__searchbar {
    display: flex;
    gap: 12px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .ona-sf__search-wrap {
    flex: 1;
    min-width: 240px;
    position: relative;
    display: flex;
  }
  .ona-sf__search {
    flex: 1;
    width: 100%;
    height: 48px;
    padding: 10px 42px 10px 18px;
    font: 16px 'Karla', sans-serif;
    color: #2b2c30;
    background: #fff;
    border: 1px solid #9e9f9b;
    box-sizing: border-box;
  }
  .ona-sf__search:focus { outline: none; border-color: #661a34; }
  .ona-sf__search-clear {
    position: absolute;
    top: 50%;
    right: 8px;
    transform: translateY(-50%);
    width: 28px;
    height: 28px;
    background: transparent;
    border: 0;
    color: #888;
    font: 20px/1 'Karla', sans-serif;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background-color .15s ease, color .15s ease;
  }
  .ona-sf__search-clear:hover { background: #eee; color: #2b2c30; }
  .ona-sf__search-clear[hidden] { display: none; }
  .ona-sf__near-me {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 48px;
    padding: 0 18px;
    background: #fff;
    border: 1px solid #ccc;
    color: #2b2c30;
    font: 14px 'Karla', sans-serif;
    cursor: pointer;
    transition: all .15s ease;
  }
  .ona-sf__near-me:hover { background: #661a34; color: #fff; border-color: #661a34; }
  .ona-sf__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
  }
  .ona-sf__chip {
    padding: 7px 14px;
    font: 13px 'Karla', sans-serif;
    color: #2b2c30;
    background: #fff;
    border: 1px solid #ccc;
    border-radius: 999px;
    cursor: pointer;
    transition: all .15s ease;
  }
  .ona-sf__chip:hover { border-color: #661a34; color: #661a34; }
  .ona-sf__chip.is-active {
    background: #661a34;
    color: #fff;
    border-color: #661a34;
  }
  /* Range slider (cocktailcompass-style) */
  .ona-sf__rs {
    margin-bottom: 24px;
    padding: 16px 20px 20px;
    background: #fff;
    border: 1px solid #e3ddd2;
  }
  .ona-sf__rs-summary {
    font: 14px 'Karla', sans-serif;
    color: #2b2c30;
    margin-bottom: 16px;
  }
  .ona-sf__rs-summary strong { color: #661a34; font-weight: 700; }
  .ona-sf__rs-track-wrap {
    position: relative;
    padding-top: 28px;
    padding-bottom: 18px;
  }
  .ona-sf__rs-input {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 4px;
    background: linear-gradient(to right, #661a34 var(--ona-sf-rs-pct, 100%), #ddd var(--ona-sf-rs-pct, 100%));
    outline: none;
    margin: 0;
    cursor: pointer;
  }
  .ona-sf__rs-input::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #661a34;
    border: 2px solid #fff;
    box-shadow: 0 1px 3px rgba(0,0,0,.3);
    cursor: pointer;
  }
  .ona-sf__rs-input::-moz-range-thumb {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #661a34;
    border: 2px solid #fff;
    box-shadow: 0 1px 3px rgba(0,0,0,.3);
    cursor: pointer;
  }
  .ona-sf__rs-input[disabled] { opacity: .4; cursor: not-allowed; }
  .ona-sf__rs-input[disabled]::-webkit-slider-thumb { background: #999; cursor: not-allowed; }
  .ona-sf__rs-bubble {
    position: absolute;
    top: 0;
    transform: translateX(-50%);
    left: var(--ona-sf-rs-pct, 100%);
    background: #2b2c30;
    color: #fff;
    font: 11px 'Karla', sans-serif;
    padding: 2px 7px;
    border-radius: 2px;
    pointer-events: none;
    white-space: nowrap;
  }
  .ona-sf__rs-bubble::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 4px solid transparent;
    border-top-color: #2b2c30;
  }
  .ona-sf__rs-ticks {
    display: flex;
    justify-content: space-between;
    margin-top: 10px;
    font: 11px 'Karla', sans-serif;
    color: #888;
  }
  .ona-sf__rs-hint {
    margin: 12px 0 0;
    font: 12px 'Karla', sans-serif;
    color: #888;
  }
  .ona-sf__rs.is-active .ona-sf__rs-hint { display: none; }
  .ona-sf__rs:not(.is-active) .ona-sf__rs-bubble { display: none; }
  .ona-sf__pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-top: 32px;
    padding: 16px 0;
    flex-wrap: wrap;
  }
  .ona-sf__page-list {
    flex: 1;
    justify-content: center;
  }
  .ona-sf__pagination[hidden] { display: none !important; }
  .ona-sf__page-btn {
    padding: 7px 0;
    font: 13px 'Karla', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    background: transparent;
    border: 0;
    color: #2b2c30;
    cursor: pointer;
    transition: color .15s ease;
  }
  .ona-sf__page-btn:hover:not([disabled]) { color: #661a34; }
  .ona-sf__page-btn[disabled] { opacity: .35; cursor: not-allowed; }
  .ona-sf__page-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .ona-sf__page-list li { line-height: 1; }
  .ona-sf__page-list button {
    width: 36px;
    height: 36px;
    border: 0;
    background: transparent;
    color: #2b2c30;
    cursor: pointer;
    font: 14px 'Karla', sans-serif;
    border-radius: 50%;
    transition: background-color .15s ease, color .15s ease;
  }
  .ona-sf__page-list button:hover { background: #f1ece4; color: #661a34; }
  .ona-sf__page-list li.is-active button {
    background: #661a34;
    color: #fff;
  }
  .ona-sf__page-list .ona-sf__page-ellipsis {
    width: 24px;
    text-align: center;
    color: #888;
    line-height: 36px;
  }
  .ona-sf__toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 0;
    border-bottom: 1px solid #e3ddd2;
    margin-bottom: 24px;
  }
  .ona-sf__count {
    font: 14px 'Karla', sans-serif;
    color: #666;
  }
  .ona-sf__view-toggle {
    display: inline-flex;
    border: 1px solid #ccc;
  }
  .ona-sf__view-btn {
    padding: 7px 16px;
    font: 13px 'Karla', sans-serif;
    background: #fff;
    border: 0;
    cursor: pointer;
    color: #2b2c30;
    outline: none;
    transition: background-color .2s ease, color .2s ease;
  }
  .ona-sf__view-btn:focus,
  .ona-sf__view-btn:focus-visible {
    outline: none;
    box-shadow: none;
  }
  .ona-sf__view-btn + .ona-sf__view-btn { border-left: 1px solid #ccc; }
  .ona-sf__view-btn:hover:not(.is-active) {
    background: #2b2c30;
    color: #fff;
  }
  .ona-sf__view-btn.is-active { background: #661a34; color: #fff; }
  .ona-sf__view-btn.is-active:hover { background: #2b2c30; }
  .ona-sf__list {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  /* In map view (sticky sidebar list), keep one column; cards take natural height */
  .ona-sf__layout[data-view="map"] .ona-sf__list {
    grid-template-columns: 1fr;
    grid-auto-rows: max-content;
    align-content: start;
  }
  .ona-sf__card {
    background: #fff;
    border: 1px solid #e3ddd2;
    padding: 20px 22px;
    transition: border-color .15s ease, box-shadow .15s ease;
    display: flex;
    flex-direction: column;
  }
  .ona-sf__card-image {
    margin: -20px -22px 16px;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #f1ece4;
  }
  .ona-sf__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ona-sf__card-overview {
    font: 14px/1.6 'Karla', sans-serif;
    color: #555;
    margin: 0 0 12px;
  }
  .ona-sf__card-overview p:last-child { margin-bottom: 0; }
  .ona-sf__card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .ona-sf__card-actions { margin-top: auto; }
  /* Active highlight only meaningful in map view (clicked from pin / card-pin sync) */
  .ona-sf__layout[data-view="map"] .ona-sf__card.is-active {
    border-color: #661a34;
    box-shadow: inset 0 0 0 2px #661a34;
  }
  .ona-sf__card-title {
    font: 500 22px/1.3 'Karla', sans-serif;
    color: #2b2c30;
    margin: 0 0 6px;
  }
  .ona-sf__card-address {
    font: 15px/1.5 'Karla', sans-serif;
    color: #555;
    margin: 0 0 10px;
  }
  .ona-sf__card-hours { font: 14px/1.6 'Karla', sans-serif; color: #555; margin-bottom: 10px; }
  .ona-sf__card-hours p { margin: 0; }
  .ona-sf__card-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 12px; }
  .ona-sf__card-tag {
    display: inline-block;
    padding: 3px 9px;
    background: #f1ece4;
    color: #5b1129;
    font: 12px 'Karla', sans-serif;
    border-radius: 999px;
  }
  .ona-sf__card-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
  }
  .ona-sf__btn {
    display: inline-flex;
    align-items: center;
    padding: 7px 14px;
    font: 13px 'Karla', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    background: transparent;
    color: #2b2c30;
    border: 1px solid #2b2c30;
    text-decoration: none;
    transition: all .15s ease;
  }
  .ona-sf__btn--primary { background: #661a34; color: #fff; border-color: #661a34; }
  .ona-sf__btn:hover,
  .ona-sf__btn:focus,
  .ona-sf__btn:focus-visible,
  .ona-sf__btn:active {
    background: #2b2c30 !important;
    color: #fff !important;
    border-color: #2b2c30 !important;
    text-decoration: none;
  }
  .ona-sf__card-distance {
    margin-left: auto;
    font: 13px 'Karla', sans-serif;
    color: #888;
  }
  .ona-sf__card-distance:empty { display: none; }
  .ona-sf__no-results {
    padding: 40px 20px;
    text-align: center;
    background: #fff;
    border: 1px dashed #ccc;
    margin-bottom: 24px;
  }
  .ona-sf__link {
    background: none;
    border: 0;
    color: #661a34;
    cursor: pointer;
    font: inherit;
    text-decoration: underline;
    padding: 0;
    transition: color .15s ease;
  }
  .ona-sf__link:hover,
  .ona-sf__link:focus,
  .ona-sf__link:focus-visible {
    color: #2b2c30;
    text-decoration: underline;
  }
  .ona-sf__map-wrap { display: none; width: 100%; }
  .ona-sf__map { width: 100%; height: 100%; min-height: 600px; background: #dedede; }
  /* Map view: split layout (list left, sticky map right) */
  .ona-sf__layout[data-view="map"] {
    display: grid;
    grid-template-columns: minmax(0, 380px) minmax(0, 1fr);
    gap: 24px;
    align-items: start;
  }
  .ona-sf__layout[data-view="map"] .ona-sf__map-wrap,
  .ona-sf__layout[data-view="map"] .ona-sf__list {
    height: 60vh;
    max-height: 600px;
    min-height: 420px;
  }
  .ona-sf__layout[data-view="map"] .ona-sf__map-wrap {
    display: block;
    position: sticky;
    top: 80px;
  }
  .ona-sf__layout[data-view="map"] .ona-sf__list {
    overflow-y: auto;
    padding-right: 6px;
  }
  .ona-sf__layout[data-view="map"] .ona-sf__pagination { display: none; }
  /* InfoWindow content + Google's default container overrides */
  .gm-style .gm-style-iw-c {
    padding: 14px 16px 16px 16px !important;
    max-height: none !important;
  }
  .gm-style .gm-style-iw-d {
    overflow: hidden !important;
    max-height: none !important;
  }
  /* Google's close-button (X) — force absolute top-right, no row of its own */
  .gm-style .gm-style-iw-c button.gm-ui-hover-effect {
    position: absolute !important;
    top: 6px !important;
    right: 6px !important;
    width: 24px !important;
    height: 24px !important;
    margin: 0 !important;
    padding: 0 !important;
  }
  .gm-style .gm-style-iw-c button.gm-ui-hover-effect span {
    margin: 4px !important;
    width: 16px !important;
    height: 16px !important;
  }
  .ona-sf__iw {
    font-family: 'Karla', sans-serif;
    color: #2b2c30;
    max-width: 360px;
  }
  @media (max-width: 749px) {
    .ona-sf__iw { max-width: calc(100vw - 80px); }
  }
  .ona-sf__iw h4 {
    font: 500 18px/1.3 'Karla', sans-serif;
    margin: 0 0 6px;
    color: #2b2c30;
  }
  .ona-sf__iw p { font: 14px/1.5 'Karla', sans-serif; margin: 0 0 8px; color: #555; }
  .ona-sf__iw-body {
    max-height: 30vh;
    overflow-y: auto;
    margin-bottom: 12px;
  }
  .ona-sf__iw-body > *:last-child { margin-bottom: 0; }
  .ona-sf__iw-hours { font: 13px/1.6 'Karla', sans-serif; color: #555; margin-bottom: 12px; }
  .ona-sf__iw-hours p { margin: 0; }
  .ona-sf__iw-btn {
    display: inline-block;
    padding: 8px 14px;
    background: #661a34;
    color: #fff;
    text-decoration: none;
    font: 12px 'Karla', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    margin-top: 4px;
  }
  .ona-sf__iw-btn:hover,
  .ona-sf__iw-btn:focus,
  .ona-sf__iw-btn:focus-visible,
  .ona-sf__iw-btn:active {
    background: #2b2c30 !important;
    color: #fff !important;
    text-decoration: none;
  }
  .ona-sf__iw-btn--secondary {
    background: transparent;
    color: #2b2c30;
    border: 1px solid #2b2c30;
  }
  .ona-sf__iw-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }
  @media (max-width: 999px) {
    .ona-sf__layout[data-view="map"] {
      grid-template-columns: 1fr;
      display: flex;
      flex-direction: column;
    }
    /* Mobile map view: map on top, list below with pagination */
    .ona-sf__layout[data-view="map"] .ona-sf__map-wrap {
      display: block;
      position: static;
      width: 100%;
      height: 50vh;
      min-height: 320px;
      max-height: 50vh;
      order: 1;
      overflow: hidden;
    }
    .ona-sf__layout[data-view="map"] .ona-sf__map {
      width: 100% !important;
      height: 100% !important;
      min-height: 0 !important;
    }
    .ona-sf__layout[data-view="map"] .ona-sf__list {
      display: grid;
      width: 100%;
      height: auto;
      max-height: 50vh;
      min-height: 0;
      overflow-y: auto;
      padding-right: 6px;
      order: 2;
      margin-top: 16px;
    }
    /* Map view on mobile uses scrollable list, not pagination */
    .ona-sf__layout[data-view="map"] .ona-sf__pagination { display: none !important; }
    /* Tablet (700-999px): 2 columns in list view */
    .ona-sf__list { width: 100%; grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 699px) {
    /* Phone: single column */
    .ona-sf__list { grid-template-columns: 1fr; }
  }
  @media (max-width: 749px) {
    .ona-sf { padding: 0 0 50px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "ONA store finder",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find a store" },
    { "type": "text", "id": "google_api_key", "label": "Google Maps API key", "info": "Restricted to ona-coffee domains in Google Cloud Console" },
    { "type": "text", "id": "fallback_lat", "label": "Fallback latitude", "default": "-35.2809" },
    { "type": "text", "id": "fallback_lng", "label": "Fallback longitude", "default": "149.1300" }
  ],
  "presets": [
    { "name": "ONA store finder" }
  ],
  "enabled_on": { "templates": ["page"] }
}
{% endschema %}
