<div class="wholesale-form pop-up-form">
  <div class="form-box">
    <div class="box">
      <a href="javascript:void(0);" class="icon-close pop-up-form-close"></a>
      <div class="title"></div>
      {formbuilder:50188}
    </div>
  </div>
</div>

<section class="full-width-image-and-text section-relative-image guest-image-block" id="wholesale-video-section">
  <div class="container">
    <div class="guest-wrap" style="display:flex;flex-wrap:wrap;align-items:center;gap:40px;">
      <div class="guest-media" style="flex:1 1 48%;min-width:300px;">
        <div class="video-box" style="position:relative;padding-bottom:56.25%;height:0;overflow:hidden;">
          <iframe
            src="https://www.youtube.com/embed/42flR1Iwun4"
            title="YouTube video player"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
            style="position:absolute;top:0;left:0;width:100%;height:100%;">
          </iframe>
        </div>
      </div>

      <div class="guest-content" style="flex:1 1 48%;min-width:300px;">
        <p style="letter-spacing:3px;text-transform:uppercase;">Join our community</p>
        <h2>A wholesale partnership with us means elevating your cafe's specialty coffee experience.</h2>
        <p>Join us for a purposeful and meaningful coffee partnership fuelled by connection and constant evolution through world-class coffee training and support.</p>
        <p>As a cafe partner, you'll have exclusive access to an exceptional range of quality coffee selections.</p>
        <p>
          <a href="javascript:void(0);" class="more-btn wholesale-roaster-form-btn">Get in touch</a>
        </p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Wholesale video",
  "settings": [],
  "presets": [
    {
      "name": "Wholesale video"
    }
  ]
}
{% endschema %}
